# Copiá este archivo a ".env" en el VPS y completá los valores reales.
# El .env NO se sube al repo (está en .gitignore).

# Conexión a PostgreSQL. Formato:
#   postgres://USUARIO:CONTRASEÑA@HOST:PUERTO/BASE
DATABASE_URL=postgres://ourhouse:CAMBIA_ESTA_CLAVE@localhost:5432/ourhouse

# Dónde escucha el proceso Node (nginx hace de proxy hacia acá).
HOST=127.0.0.1
PORT=4321
