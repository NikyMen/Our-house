---
interface Props {
  title?: string;
}
const { title = 'OurHouse · Gastos del hogar' } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#070b1a" />
    <meta name="description" content="Lleva el control de los gastos del hogar de forma sencilla." />
    <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Ctext y='.9em' font-size='90'%3E%F0%9F%8F%A0%3C/text%3E%3C/svg%3E" />
    <title>{title}</title>
  </head>
  <body>
    <div class="bg-scene" aria-hidden="true">
      <span class="blob blob-a"></span>
      <span class="blob blob-b"></span>
      <span class="blob blob-c"></span>
      <span class="bg-grid"></span>
    </div>
    <slot />
  </body>
</html>

<style is:global>
  :root {
    /* ── Base ── */
    --bg: #070b1a;
    --text: #eef2ff;
    --text-muted: #9aa8cb;
    --accent: #6366f1;
    --accent-hover: #818cf8;
    --danger: #ef4444;
    --ok: #10b981;
    --warn: #f59e0b;
    --radius: 20px;

    /* ── Glassmorphism ── */
    --glass-bg: linear-gradient(
      160deg,
      rgba(255, 255, 255, 0.11) 0%,
      rgba(255, 255, 255, 0.045) 42%,
      rgba(255, 255, 255, 0.02) 100%
    );
    --glass-bg-strong: linear-gradient(
      160deg,
      rgba(255, 255, 255, 0.16) 0%,
      rgba(255, 255, 255, 0.07) 50%,
      rgba(255, 255, 255, 0.03) 100%
    );
    --glass-filter: blur(18px) saturate(1.6);
    --glass-border: rgba(255, 255, 255, 0.13);
    --glass-border-hover: rgba(255, 255, 255, 0.24);
    --glass-shadow: 0 18px 40px -18px rgba(2, 6, 23, 0.65), inset 0 1px 0 rgba(255, 255, 255, 0.1);
    --shadow: var(--glass-shadow);

    /* Superficies translúcidas (elementos internos, sin backdrop-filter). */
    --surface: rgba(30, 41, 66, 0.55);
    --surface-2: rgba(64, 79, 116, 0.28);
    --border: rgba(148, 163, 197, 0.2);

    /* ── Colores de gráficos (validados sobre superficie oscura) ── */
    --chart-gasto: #6366f1;
    --chart-ingreso: #059669;
    --chart-context: #64748b;
    --chart-grid: rgba(148, 163, 197, 0.14);
  }

  * {
    box-sizing: border-box;
  }

  html {
    color-scheme: dark;
    /* Reserva el espacio del scrollbar: evita el salto de ancho cuando
       aparece (y que los gráficos se redibujen sin su animación). */
    scrollbar-gutter: stable;
  }

  ::-webkit-scrollbar {
    width: 10px;
    height: 10px;
  }

  ::-webkit-scrollbar-thumb {
    background: rgba(148, 163, 197, 0.28);
    border-radius: 999px;
    border: 2px solid transparent;
    background-clip: padding-box;
  }

  ::-webkit-scrollbar-thumb:hover {
    background: rgba(148, 163, 197, 0.45);
    background-clip: padding-box;
    border: 2px solid transparent;
  }

  ::-webkit-scrollbar-track {
    background: transparent;
  }

  body {
    margin: 0;
    font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
    background: var(--bg);
    color: var(--text);
    min-height: 100dvh;
    line-height: 1.5;
    overflow-x: hidden;
  }

  /* ═══ Fondo aurora: blobs de gradiente flotando tras el vidrio ═══ */
  .bg-scene {
    position: fixed;
    inset: 0;
    z-index: -1;
    overflow: hidden;
    background:
      radial-gradient(1100px 700px at 85% -15%, rgba(49, 46, 129, 0.55) 0%, transparent 60%),
      radial-gradient(900px 600px at -10% 110%, rgba(6, 78, 59, 0.4) 0%, transparent 55%),
      var(--bg);
  }

  .blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.5;
    will-change: transform;
  }

  .blob-a {
    width: 46vmax;
    height: 46vmax;
    left: -12vmax;
    top: -14vmax;
    background: radial-gradient(circle at 30% 30%, #4338ca 0%, #6d28d9 45%, transparent 72%);
    animation: blob-drift-a 26s ease-in-out infinite alternate;
  }

  .blob-b {
    width: 38vmax;
    height: 38vmax;
    right: -10vmax;
    top: 22%;
    background: radial-gradient(circle at 60% 40%, #0f766e 0%, #047857 50%, transparent 74%);
    animation: blob-drift-b 32s ease-in-out infinite alternate;
  }

  .blob-c {
    width: 34vmax;
    height: 34vmax;
    left: 24%;
    bottom: -18vmax;
    background: radial-gradient(circle at 50% 50%, #9d174d 0%, #7e22ce 55%, transparent 75%);
    animation: blob-drift-c 38s ease-in-out infinite alternate;
    opacity: 0.34;
  }

  /* Malla sutil que le da textura al vidrio. */
  .bg-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(148, 163, 197, 0.045) 1px, transparent 1px),
      linear-gradient(90deg, rgba(148, 163, 197, 0.045) 1px, transparent 1px);
    background-size: 44px 44px;
    mask-image: radial-gradient(75% 60% at 50% 34%, rgba(0, 0, 0, 0.85), transparent 100%);
    -webkit-mask-image: radial-gradient(75% 60% at 50% 34%, rgba(0, 0, 0, 0.85), transparent 100%);
  }

  @keyframes blob-drift-a {
    from { transform: translate3d(0, 0, 0) scale(1); }
    to   { transform: translate3d(9vmax, 7vmax, 0) scale(1.14); }
  }

  @keyframes blob-drift-b {
    from { transform: translate3d(0, 0, 0) scale(1.08); }
    to   { transform: translate3d(-8vmax, -6vmax, 0) scale(0.94); }
  }

  @keyframes blob-drift-c {
    from { transform: translate3d(0, 0, 0) scale(1); }
    to   { transform: translate3d(6vmax, -9vmax, 0) scale(1.18); }
  }

  h1,
  h2,
  h3 {
    margin: 0;
    font-weight: 650;
    letter-spacing: -0.01em;
  }

  button {
    font: inherit;
    cursor: pointer;
  }

  input,
  select {
    font: inherit;
    color: var(--text);
    background: rgba(10, 16, 34, 0.55);
    border: 1px solid var(--glass-border);
    border-radius: 12px;
    padding: 0.6rem 0.75rem;
    width: 100%;
    box-shadow: inset 0 2px 6px rgba(2, 6, 23, 0.35);
    transition: border-color 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
  }

  input:hover,
  select:hover {
    border-color: var(--glass-border-hover);
  }

  input:focus,
  select:focus {
    outline: none;
    border-color: var(--accent-hover);
    background: rgba(10, 16, 34, 0.75);
    box-shadow:
      inset 0 2px 6px rgba(2, 6, 23, 0.35),
      0 0 0 3px rgba(99, 102, 241, 0.28),
      0 0 18px -4px rgba(99, 102, 241, 0.45);
  }

  ::placeholder {
    color: var(--text-muted);
    opacity: 0.75;
  }

  ::selection {
    background: rgba(99, 102, 241, 0.45);
  }

  /* ═══ Receta de vidrio compartida (la usan las .card de cada página) ═══ */
  .glass,
  .card {
    background: var(--glass-bg);
    -webkit-backdrop-filter: var(--glass-filter);
    backdrop-filter: var(--glass-filter);
    border: 1px solid var(--glass-border);
    border-radius: var(--radius);
    box-shadow: var(--glass-shadow);
    transition: border-color 0.25s ease, box-shadow 0.25s ease, transform 0.25s ease;
  }

  /* ═══ Animaciones de entrada reutilizables ═══ */
  @keyframes rise-in {
    from {
      opacity: 0;
      transform: translateY(18px) scale(0.985);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  @keyframes pop-in {
    0% { opacity: 0; transform: scale(0.86); }
    70% { transform: scale(1.03); }
    100% { opacity: 1; transform: scale(1); }
  }

  @keyframes shimmer-slide {
    from { background-position: -200% 0; }
    to { background-position: 200% 0; }
  }

  /* Placeholder brillante mientras un gráfico se dibuja por primera vez. */
  .shimmer {
    border-radius: 14px;
    background:
      linear-gradient(100deg, transparent 30%, rgba(255, 255, 255, 0.08) 50%, transparent 70%),
      rgba(148, 163, 197, 0.07);
    background-size: 200% 100%, auto;
    animation: shimmer-slide 1.4s linear infinite;
  }

  /* En móvil los inputs con menos de 16px provocan zoom automático en iOS. */
  @media (max-width: 820px) {
    input,
    select {
      font-size: 16px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .blob {
      animation: none !important;
    }
    *,
    *::before,
    *::after {
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0.01ms !important;
    }
  }
</style>
