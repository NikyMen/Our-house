  function renderSummary(
    monthly: ReturnType<typeof filterByMonth>,
    monthIncome: ReturnType<typeof filterIncomeByMonth>
  ): void {
    const fixedVirtual = fixedAsExpenses(fixed, selectedMonth);
    const combined = [...monthly, ...fixedVirtual];
    const gastoTotal = total(combined);
    const ingresoTotal = incomeTotal(monthIncome);
    const saldo = ingresoTotal - gastoTotal;

    // Saldo card
    const saldoCard = $<HTMLElement>('#saldo-card');
    animateNumber($<HTMLElement>('#saldo-value'), saldo, money);
    const ingrText = monthIncome.length === 0 ? 'Sin ingresos' : `${money(ingresoTotal)} ingresados`;
    $<HTMLElement>('#saldo-hint').textContent = `${ingrText} · ${money(gastoTotal)} gastados`;
    saldoCard.classList.toggle('saldo-negative', saldo < 0);

    // Income month total hint
    $<HTMLElement>('#income-month-total').textContent =
      monthIncome.length === 0 ? '' : `${money(ingresoTotal)} este mes`;

    // Totales en vivo de la barra de navegación desktop
    $<HTMLElement>('#dtab-sub-gastos').textContent = money(total(monthly));
    $<HTMLElement>('#dtab-sub-ingresos').textContent = money(ingresoTotal);
    $<HTMLElement>('#dtab-sub-fijos').textContent = `${money(fixedCostsTotal(fixed))}/mes`;

    // Dona por categoría + leyenda con micro-barras (la lista es la tabla de datos)
    renderDonut(combined);

    const catList = $<HTMLUListElement>('#by-category');
    catList.innerHTML = '';
    const sortedCats = [...totalsByCategory(combined).entries()].sort((a, b) => b[1] - a[1]);
    if (sortedCats.length === 0) {
      catList.append(emptyLi());
    } else {
      const catSum = sortedCats.reduce((s, [, v]) => s + v, 0);
      const catMax = sortedCats[0]?.[1] ?? 1;
      for (const [cat, amount] of sortedCats) {
        const c = getCategory(cat);
        catList.append(breakdownRow(`${c.emoji} ${c.label}`, amount, amount / catSum, amount / catMax, c.color));
      }
    }

    const personList = $<HTMLUListElement>('#by-person');
    personList.innerHTML = '';
    const memberNames = house.members.map((m) => m.displayName);
    const sortedPeople = [...totalsByPerson(combined, memberNames).entries()].sort((a, b) => b[1] - a[1]);
    if (sortedPeople.length === 0) {
      personList.append(emptyLi());
    } else {
      const personSum = sortedPeople.reduce((s, [, v]) => s + v, 0);
      const personMax = sortedPeople[0]?.[1] ?? 1;
      for (const [person, amount] of sortedPeople) {
        // Una sola serie (magnitud por persona): todas las barras en el mismo tono.
        personList.append(breakdownRow(`👤 ${person}`, amount, amount / personSum, amount / personMax, 'var(--chart-gasto)'));
      }
    }

    // Disparar el crecimiento animado de las micro-barras ya montadas.
    requestAnimationFrame(() => {
      for (const bar of document.querySelectorAll<HTMLElement>('.breakdown .b-bar-fill')) {
        bar.style.width = bar.dataset.w ?? '0%';
      }
    });
  }

  /**
   * Fila de desglose con micro-barra de proporción.
   * `share` = fracción del total (para el %); `rel` = fracción vs la mayor (ancho de barra).
   */
  function breakdownRow(
    label: string,
    amount: number,
    share: number,
    rel: number,
    color: string
  ): HTMLLIElement {
    const li = document.createElement('li');
    li.className = 'b-row';

    const top = document.createElement('div');
    top.className = 'b-top';
    const name = document.createElement('span');
    name.className = 'b-name';
    name.textContent = label;
    const right = document.createElement('span');
    right.className = 'b-right';
    const value = document.createElement('span');
    value.className = 'b-value';
    value.textContent = money(amount);
    const pct = document.createElement('span');
    pct.className = 'b-pct';
    pct.textContent = `${Math.round(share * 100)}%`;
    right.append(value, pct);
    top.append(name, right);

    const bar = document.createElement('div');
    bar.className = 'b-bar';
    const fill = document.createElement('span');
    fill.className = 'b-bar-fill';
    fill.style.background = color;
    fill.dataset.w = `${Math.max(2, Math.round(rel * 100))}%`;
    bar.append(fill);

    li.append(top, bar);
    return li;
  }

