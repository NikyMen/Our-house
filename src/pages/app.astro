---
import Layout from '../layouts/Layout.astro';
import { CATEGORIES, INCOME_TYPES } from '../lib/types';
---

<Layout title="OurHouse · App">
  <div class="page" id="page" data-view="resumen" data-add-mode="gasto">
    <header class="header">
      <div class="brand">
        <span class="logo">🏠</span>
        <div>
          <h1>OurHouse</h1>
          <p id="house-tagline" class="tagline">Gastos del hogar</p>
        </div>
      </div>
      <div class="header-right">
        <div class="house-chip" title="Código de invitación de la casa">
          <span class="house-chip-label">Invitar:</span>
          <code id="house-code" class="house-code"></code>
          <button id="copy-code-btn" class="btn-copy" type="button" title="Copiar código de invitación">📋</button>
          <a class="btn-house" href="/casa?elegir=1">Cambiar casa</a>
        </div>
        <div class="month-pick">
          <label for="month-select">Mes</label>
          <select id="month-select" aria-label="Seleccionar mes"></select>
        </div>
        <button id="hide-btn" class="btn-hide" type="button" aria-pressed="false" title="Ocultar importes">
          👁️ Ocultar
        </button>
        <div class="user-area">
          <span id="user-greeting" class="user-greeting"></span>
          <button id="logout-btn" class="btn-logout" type="button">Salir</button>
        </div>
      </div>
    </header>

    <section class="summary">
      <article class="card saldo-card" id="saldo-card">
        <span class="card-label">Saldo del mes</span>
        <strong id="saldo-value" class="total-value">—</strong>
        <span id="saldo-hint" class="card-hint"></span>
      </article>
      <article class="card">
        <span class="card-label">Por categoría</span>
        <ul id="by-category" class="breakdown"></ul>
      </article>
      <article class="card">
        <span class="card-label">Quién pagó</span>
        <ul id="by-person" class="breakdown"></ul>
      </article>
    </section>

    <section class="layout-grid">
      <div class="form-col">
        <div class="add-switch" role="tablist" aria-label="Tipo de movimiento">
          <button type="button" class="add-tab active" data-mode="gasto" role="tab" aria-selected="true">
            💸 Gasto
          </button>
          <button type="button" class="add-tab" data-mode="ingreso" role="tab" aria-selected="false">
            💰 Ingreso
          </button>
        </div>

        <aside class="card form-card card-expense">
          <h2>Nuevo gasto</h2>
          <form id="expense-form" autocomplete="off">
            <div class="field">
              <label for="description">Descripción</label>
              <input id="description" name="description" type="text" placeholder="Compra semanal" required maxlength="80" />
            </div>
            <div class="field-row">
              <div class="field">
                <label for="amount">Importe ($)</label>
                <input id="amount" name="amount" type="number" inputmode="decimal" step="0.01" min="0.01" placeholder="0,00" required />
              </div>
              <div class="field">
                <label for="date">Fecha</label>
                <input id="date" name="date" type="date" required />
              </div>
            </div>
            <div class="field-row">
              <div class="field">
                <label for="category">Categoría</label>
                <select id="category" name="category">
                  {CATEGORIES.map((c) => <option value={c.id}>{c.emoji} {c.label}</option>)}
                </select>
              </div>
              <div class="field">
                <label for="paidBy">Pagado por</label>
                <select id="paidBy" name="paidBy" required></select>
              </div>
            </div>
            <button type="submit" class="btn-primary">Añadir gasto</button>
          </form>
        </aside>

        <aside class="card form-card income-form-card card-income">
          <div class="list-head">
            <h2>Cargar saldo</h2>
            <span id="income-month-total" class="card-hint"></span>
          </div>
          <form id="income-form" autocomplete="off">
            <div class="field">
              <label for="income-description">Descripción</label>
              <input id="income-description" name="description" type="text" placeholder="Sueldo julio, trabajo extra…" required maxlength="80" />
            </div>
            <div class="field-row">
              <div class="field">
                <label for="income-amount">Importe ($)</label>
                <input id="income-amount" name="amount" type="number" inputmode="decimal" step="0.01" min="0.01" placeholder="0,00" required />
              </div>
              <div class="field">
                <label for="income-date">Fecha</label>
                <input id="income-date" name="date" type="date" required />
              </div>
            </div>
            <div class="field-row">
              <div class="field">
                <label for="income-type">Tipo</label>
                <select id="income-type" name="type">
                  {INCOME_TYPES.map((t) => <option value={t.id}>{t.emoji} {t.label}</option>)}
                </select>
              </div>
              <div class="field">
                <label for="income-person">Persona</label>
                <select id="income-person" name="person" required></select>
              </div>
            </div>
            <button type="submit" class="btn-income">Añadir ingreso</button>
          </form>
        </aside>

        <aside class="card form-card card-fixed">
          <div class="list-head">
            <h2>Costos fijos</h2>
            <span id="fixed-total" class="card-hint"></span>
          </div>
          <p class="fixed-help">Se suman automáticamente todos los meses.</p>
          <form id="fixed-form" autocomplete="off">
            <div class="field">
              <label for="fixed-description">Descripción</label>
              <input id="fixed-description" name="description" type="text" placeholder="Alquiler, internet…" required maxlength="80" />
            </div>
            <div class="field-row">
              <div class="field">
                <label for="fixed-amount">Importe ($)</label>
                <input id="fixed-amount" name="amount" type="number" inputmode="decimal" step="0.01" min="0.01" placeholder="0,00" required />
              </div>
              <div class="field">
                <label for="fixed-category">Categoría</label>
                <select id="fixed-category" name="category">
                  {CATEGORIES.map((c) => <option value={c.id}>{c.emoji} {c.label}</option>)}
                </select>
              </div>
            </div>
            <div class="field">
              <label for="fixed-paidBy">Pagado por</label>
              <select id="fixed-paidBy" name="paidBy" required></select>
            </div>
            <button type="submit" class="btn-primary">Añadir costo fijo</button>
          </form>
          <ul id="fixed-list" class="expense-list fixed-list"></ul>
          <p id="fixed-empty" class="empty" hidden>Sin costos fijos todavía.</p>
        </aside>
      </div>

      <section class="card list-card">
        <div class="list-head">
          <h2>Movimientos</h2>
          <span id="list-count" class="card-hint"></span>
        </div>
        <ul id="expense-list" class="expense-list"></ul>
        <p id="empty-state" class="empty" hidden>
          Todavía no hay movimientos este mes.
          <span class="only-desktop">¡Cargá tu saldo o añadí un gasto! 👈</span>
          <span class="only-mobile">Tocá el botón ➕ para cargar tu saldo o añadir un gasto.</span>
        </p>
      </section>
    </section>

    <section class="card settings-card" aria-label="Ajustes">
      <h2>Ajustes</h2>
      <p id="settings-user" class="settings-user"></p>

      <div class="settings-block">
        <span class="settings-label">Casa actual</span>
        <p id="settings-house-name" class="settings-house-name"></p>
        <p id="settings-house-members" class="settings-house-members"></p>
      </div>

      <div class="settings-block">
        <span class="settings-label">Código de invitación</span>
        <div class="settings-code-row">
          <code id="settings-house-code" class="house-code settings-code"></code>
          <button id="settings-copy-btn" class="settings-copy" type="button">📋 Copiar</button>
        </div>
      </div>

      <div class="settings-actions">
        <a class="settings-btn" href="/casa?elegir=1">🔁 Cambiar de casa</a>
        <button id="settings-hide-btn" class="settings-btn" type="button" aria-pressed="false">
          👁️ Ocultar importes
        </button>
        <button id="settings-logout-btn" class="settings-btn settings-danger" type="button">
          🚪 Cerrar sesión
        </button>
      </div>

      <p class="settings-note">
        Los datos de cada casa se guardan solo en este navegador (localStorage).
        Compartí el código de invitación para que los demás se unan desde este mismo navegador.
      </p>
    </section>

    <footer class="foot">
      Los datos de cada casa se guardan solo en este navegador (localStorage).
      Compartí el código de invitación para que los demás se unan desde este mismo navegador.
    </footer>
  </div>

  <nav class="mobile-nav" aria-label="Navegación principal">
    <button class="nav-item active" type="button" data-view="resumen">
      <span class="nav-icon">📊</span>
      <span>Resumen</span>
    </button>
    <button class="nav-item" type="button" data-view="movs">
      <span class="nav-icon">🧾</span>
      <span>Movim.</span>
    </button>
    <button class="nav-fab" type="button" data-view="add" aria-label="Añadir gasto o ingreso">＋</button>
    <button class="nav-item" type="button" data-view="fijos">
      <span class="nav-icon">📌</span>
      <span>Fijos</span>
    </button>
    <button class="nav-item" type="button" data-view="ajustes">
      <span class="nav-icon">⚙️</span>
      <span>Ajustes</span>
    </button>
  </nav>

  <template id="expense-row-tpl">
    <li class="expense-item">
      <span class="cat-dot"></span>
      <div class="expense-main">
        <span class="expense-desc"></span>
        <span class="expense-meta"></span>
      </div>
      <span class="expense-amount"></span>
      <button class="btn-del" type="button" aria-label="Eliminar gasto" title="Eliminar">✕</button>
    </li>
  </template>

  <template id="income-row-tpl">
    <li class="expense-item income-item">
      <span class="cat-dot income-dot"></span>
      <div class="expense-main">
        <span class="expense-desc"></span>
        <span class="expense-meta"></span>
      </div>
      <span class="expense-amount income-amount"></span>
      <button class="btn-del" type="button" aria-label="Eliminar ingreso" title="Eliminar">✕</button>
    </li>
  </template>
</Layout>

<script>
  import {
    addExpense,
    addFixedCost,
    addIncome,
    availableMonths,
    deleteExpense,
    deleteFixedCost,
    deleteIncome,
    filterByMonth,
    filterIncomeByMonth,
    fixedAsExpenses,
    fixedCostsTotal,
    incomeTotal,
    loadExpenses,
    loadFixedCosts,
    loadIncome,
    total,
    totalsByCategory,
    totalsByPerson,
  } from '../lib/store';
  import { CATEGORIES, INCOME_TYPES, getCategory, type CategoryId } from '../lib/types';
  import { formatDate, formatMonth, formatMoney, monthKeyOf, todayISO } from '../lib/format';
  import { getCurrentUser, logout, type User } from '../lib/auth';
  import { getActiveHouse, type House } from '../lib/house';

  const user = getCurrentUser();
  if (!user) {
    window.location.replace('/');
  }
  const maybeHouse = user ? getActiveHouse(user) : null;
  if (user && !maybeHouse) {
    window.location.replace('/casa');
  }

  // Si falta sesión o casa ya se disparó la redirección; estos valores solo se
  // usan mientras la página sigue viva.
  const currentUser: User = user ?? { username: '', displayName: '' };
  let house: House = maybeHouse ?? {
    id: '',
    name: '',
    inviteCode: '',
    owner: '',
    members: [],
    createdAt: '',
  };

  const $ = <T extends HTMLElement>(sel: string): T => {
    const el = document.querySelector<T>(sel);
    if (!el) throw new Error(`No se encontró ${sel}`);
    return el;
  };

  const form           = $<HTMLFormElement>('#expense-form');
  const monthSelect    = $<HTMLSelectElement>('#month-select');
  const list           = $<HTMLUListElement>('#expense-list');
  const emptyState     = $<HTMLParagraphElement>('#empty-state');
  const rowTpl         = $<HTMLTemplateElement>('#expense-row-tpl');
  const incomeRowTpl   = $<HTMLTemplateElement>('#income-row-tpl');
  const dateInput      = $<HTMLInputElement>('#date');
  const paidBySelect   = $<HTMLSelectElement>('#paidBy');
  const personSelect   = $<HTMLSelectElement>('#income-person');
  const fixedPaidBySel = $<HTMLSelectElement>('#fixed-paidBy');
  const fixedForm      = $<HTMLFormElement>('#fixed-form');
  const fixedList      = $<HTMLUListElement>('#fixed-list');
  const fixedEmpty     = $<HTMLParagraphElement>('#fixed-empty');
  const fixedTotalEl   = $<HTMLSpanElement>('#fixed-total');
  const incomeForm     = $<HTMLFormElement>('#income-form');
  const hideBtn        = $<HTMLButtonElement>('#hide-btn');
  const logoutBtn      = $<HTMLButtonElement>('#logout-btn');
  const copyCodeBtn    = $<HTMLButtonElement>('#copy-code-btn');
  const pageEl         = $<HTMLDivElement>('#page');
  const settingsHide   = $<HTMLButtonElement>('#settings-hide-btn');
  const settingsLogout = $<HTMLButtonElement>('#settings-logout-btn');
  const settingsCopy   = $<HTMLButtonElement>('#settings-copy-btn');
  const navItems = [...document.querySelectorAll<HTMLButtonElement>('.mobile-nav [data-view]')];
  const addTabs  = [...document.querySelectorAll<HTMLButtonElement>('.add-tab')];

  const mobileMq = window.matchMedia('(max-width: 820px)');
  const isMobile = (): boolean => mobileMq.matches;

  const HIDE_KEY = 'ourhouse.hideMoney.v1';
  let moneyHidden = localStorage.getItem(HIDE_KEY) === '1';
  const money = (amount: number): string => moneyHidden ? '••••••' : formatMoney(amount);

  let expenses = loadExpenses(house.id);
  let fixed = loadFixedCosts(house.id);
  let income = loadIncome(house.id);
  let selectedMonth = '';

  $<HTMLSpanElement>('#user-greeting').textContent = `Hola, ${currentUser.displayName}`;
  $<HTMLParagraphElement>('#settings-user').textContent = `Hola, ${currentUser.displayName} 👋`;

  function renderHouseHeader(): void {
    const n = house.members.length;
    const membersText = `${n} ${n === 1 ? 'integrante' : 'integrantes'}`;
    $<HTMLParagraphElement>('#house-tagline').textContent = `🏡 ${house.name} · ${membersText}`;
    $<HTMLElement>('#house-code').textContent = house.inviteCode;
    $<HTMLParagraphElement>('#settings-house-name').textContent = `🏡 ${house.name}`;
    $<HTMLParagraphElement>('#settings-house-members').textContent =
      `${membersText}: ${house.members.map((m) => m.displayName).join(', ')}`;
    $<HTMLElement>('#settings-house-code').textContent = house.inviteCode;
  }

  /* ── Navegación mobile por vistas ── */
  function setView(view: string): void {
    pageEl.dataset.view = view;
    for (const b of navItems) b.classList.toggle('active', b.dataset.view === view);
    window.scrollTo(0, 0);
  }

  for (const b of navItems) {
    b.addEventListener('click', () => setView(b.dataset.view!));
  }

  for (const tab of addTabs) {
    tab.addEventListener('click', () => {
      pageEl.dataset.addMode = tab.dataset.mode;
      for (const t of addTabs) {
        t.classList.toggle('active', t === tab);
        t.setAttribute('aria-selected', String(t === tab));
      }
    });
  }

  /** Rellena los selects de persona con los integrantes de la casa. */
  function populateMemberSelects(): void {
    for (const sel of [paidBySelect, personSelect, fixedPaidBySel]) {
      const previous = sel.value;
      sel.innerHTML = '';
      for (const m of house.members) {
        const opt = document.createElement('option');
        opt.value = m.displayName;
        opt.textContent = m.displayName;
        sel.append(opt);
      }
      sel.value = house.members.some((m) => m.displayName === previous)
        ? previous
        : currentUser.displayName;
    }
  }

  function render(): void {
    const expMonths = availableMonths(expenses);
    const incMonthSet = new Set(income.map((i) => monthKeyOf(i.date)));
    const currentMonth = monthKeyOf(todayISO());
    const months = [...new Set([...expMonths, ...incMonthSet, currentMonth])].sort((a, b) =>
      b.localeCompare(a)
    );

    if (!selectedMonth || !months.includes(selectedMonth)) {
      selectedMonth = months.includes(currentMonth) ? currentMonth : months[0]!;
    }

    monthSelect.innerHTML = '';
    for (const m of months) {
      const opt = document.createElement('option');
      opt.value = m;
      opt.textContent = formatMonth(m);
      opt.selected = m === selectedMonth;
      monthSelect.append(opt);
    }

    const monthly = filterByMonth(expenses, selectedMonth);
    const monthIncome = filterIncomeByMonth(income, selectedMonth);
    renderSummary(monthly, monthIncome);
    renderList(monthly, monthIncome);
    renderFixed();
  }

  function renderSummary(
    monthly: ReturnType<typeof filterByMonth>,
    monthIncome: ReturnType<typeof filterIncomeByMonth>
  ): void {
    const fixedVirtual = fixedAsExpenses(fixed, selectedMonth);
    const combined = [...monthly, ...fixedVirtual];
    const gastoTotal = total(combined);
    const ingresoTotal = incomeTotal(monthIncome);
    const saldo = ingresoTotal - gastoTotal;

    // Saldo card
    const saldoCard = $<HTMLElement>('#saldo-card');
    $<HTMLElement>('#saldo-value').textContent = money(saldo);
    const ingrText = monthIncome.length === 0 ? 'Sin ingresos' : `${money(ingresoTotal)} ingresados`;
    $<HTMLElement>('#saldo-hint').textContent = `${ingrText} · ${money(gastoTotal)} gastados`;
    saldoCard.classList.toggle('saldo-negative', saldo < 0);

    // Income month total hint
    $<HTMLElement>('#income-month-total').textContent =
      monthIncome.length === 0 ? '' : `${money(ingresoTotal)} este mes`;

    const catList = $<HTMLUListElement>('#by-category');
    catList.innerHTML = '';
    const sortedCats = [...totalsByCategory(combined).entries()].sort((a, b) => b[1] - a[1]);
    if (sortedCats.length === 0) {
      catList.append(emptyLi());
    } else {
      for (const [cat, amount] of sortedCats) {
        const c = getCategory(cat);
        catList.append(breakdownLi(`${c.emoji} ${c.label}`, amount, c.color));
      }
    }

    const personList = $<HTMLUListElement>('#by-person');
    personList.innerHTML = '';
    const sortedPeople = [...totalsByPerson(combined).entries()].sort((a, b) => b[1] - a[1]);
    if (sortedPeople.length === 0) {
      personList.append(emptyLi());
    } else {
      for (const [person, amount] of sortedPeople) {
        personList.append(breakdownLi(`👤 ${person}`, amount));
      }
    }
  }

  function breakdownLi(label: string, amount: number, color?: string): HTMLLIElement {
    const li = document.createElement('li');
    const name = document.createElement('span');
    name.className = 'b-name';
    if (color) {
      const dot = document.createElement('span');
      dot.className = 'b-dot';
      dot.style.background = color;
      name.append(dot);
    }
    name.append(document.createTextNode(label));
    const value = document.createElement('span');
    value.className = 'b-value';
    value.textContent = money(amount);
    li.append(name, value);
    return li;
  }

  function emptyLi(): HTMLLIElement {
    const li = document.createElement('li');
    li.className = 'b-empty';
    li.textContent = '—';
    return li;
  }

  function renderList(
    monthly: ReturnType<typeof filterByMonth>,
    monthIncome: ReturnType<typeof filterIncomeByMonth>
  ): void {
    list.innerHTML = '';
    const totalItems = monthly.length + monthIncome.length;
    emptyState.hidden = totalItems > 0;

    const expText = monthly.length === 0 ? '' : `${monthly.length} ${monthly.length === 1 ? 'gasto' : 'gastos'}`;
    const incText = monthIncome.length === 0 ? '' : `${monthIncome.length} ${monthIncome.length === 1 ? 'ingreso' : 'ingresos'}`;
    $<HTMLElement>('#list-count').textContent = [expText, incText].filter(Boolean).join(' · ');

    type Item =
      | { kind: 'expense'; date: string; id: string }
      | { kind: 'income'; date: string; id: string };

    const merged: Item[] = [
      ...monthly.map((e) => ({ kind: 'expense' as const, date: e.date, id: e.id })),
      ...monthIncome.map((i) => ({ kind: 'income' as const, date: i.date, id: i.id })),
    ].sort((a, b) => b.date.localeCompare(a.date));

    const expenseMap = new Map(monthly.map((e) => [e.id, e]));
    const incomeMap = new Map(monthIncome.map((i) => [i.id, i]));

    for (const item of merged) {
      if (item.kind === 'expense') {
        const e = expenseMap.get(item.id)!;
        const node = rowTpl.content.firstElementChild!.cloneNode(true) as HTMLLIElement;
        const c = getCategory(e.category);
        node.querySelector<HTMLSpanElement>('.cat-dot')!.style.background = c.color;
        node.querySelector<HTMLSpanElement>('.expense-desc')!.textContent = e.description;
        node.querySelector<HTMLSpanElement>('.expense-meta')!.textContent =
          `${c.emoji} ${c.label} · ${formatDate(e.date)} · ${e.paidBy}`;
        node.querySelector<HTMLSpanElement>('.expense-amount')!.textContent = money(e.amount);
        node.querySelector<HTMLButtonElement>('.btn-del')!.addEventListener('click', () => {
          expenses = deleteExpense(house.id, e.id);
          render();
        });
        list.append(node);
      } else {
        const inc = incomeMap.get(item.id)!;
        const node = incomeRowTpl.content.firstElementChild!.cloneNode(true) as HTMLLIElement;
        const typeInfo = INCOME_TYPES.find((t) => t.id === inc.type) ?? INCOME_TYPES[0]!;
        node.querySelector<HTMLSpanElement>('.expense-desc')!.textContent = inc.description;
        node.querySelector<HTMLSpanElement>('.expense-meta')!.textContent =
          `${typeInfo.emoji} ${typeInfo.label} · ${formatDate(inc.date)} · ${inc.person}`;
        node.querySelector<HTMLSpanElement>('.expense-amount')!.textContent = `+${money(inc.amount)}`;
        node.querySelector<HTMLButtonElement>('.btn-del')!.addEventListener('click', () => {
          income = deleteIncome(house.id, inc.id);
          render();
        });
        list.append(node);
      }
    }
  }

  function renderFixed(): void {
    fixedTotalEl.textContent = fixed.length === 0 ? '' : `${money(fixedCostsTotal(fixed))} / mes`;
    fixedList.innerHTML = '';
    fixedEmpty.hidden = fixed.length > 0;

    for (const f of fixed) {
      const node = rowTpl.content.firstElementChild!.cloneNode(true) as HTMLLIElement;
      const c = getCategory(f.category);
      node.querySelector<HTMLSpanElement>('.cat-dot')!.style.background = c.color;
      node.querySelector<HTMLSpanElement>('.expense-desc')!.textContent = f.description;
      node.querySelector<HTMLSpanElement>('.expense-meta')!.textContent =
        `${c.emoji} ${c.label} · cada mes · ${f.paidBy}`;
      node.querySelector<HTMLSpanElement>('.expense-amount')!.textContent = money(f.amount);
      node.querySelector<HTMLButtonElement>('.btn-del')!.addEventListener('click', () => {
        fixed = deleteFixedCost(house.id, f.id);
        render();
      });
      fixedList.append(node);
    }
  }

  function bindCopy(btn: HTMLButtonElement, doneText: string): void {
    const original = btn.textContent;
    btn.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(house.inviteCode);
        btn.textContent = doneText;
        setTimeout(() => (btn.textContent = original), 1500);
      } catch {
        // Sin clipboard: el código ya está visible al lado del botón.
      }
    });
  }
  bindCopy(copyCodeBtn, '✅');
  bindCopy(settingsCopy, '✅ Copiado');

  for (const btn of [logoutBtn, settingsLogout]) {
    btn.addEventListener('click', () => {
      logout();
      window.location.replace('/');
    });
  }

  form.addEventListener('submit', (e) => {
    e.preventDefault();
    const data = new FormData(form);
    const amount = Number.parseFloat(String(data.get('amount')).replace(',', '.'));
    if (!Number.isFinite(amount) || amount <= 0) {
      $<HTMLInputElement>('#amount').focus();
      return;
    }
    expenses = addExpense(house.id, {
      description: String(data.get('description')).trim(),
      amount: Math.round(amount * 100) / 100,
      category: String(data.get('category')) as CategoryId,
      paidBy: String(data.get('paidBy')).trim(),
      date: String(data.get('date')) || todayISO(),
    });
    selectedMonth = monthKeyOf(String(data.get('date')) || todayISO());
    form.reset();
    dateInput.value = todayISO();
    paidBySelect.value = currentUser.displayName;
    if (isMobile()) {
      setView('movs');
    } else {
      $<HTMLInputElement>('#description').focus();
    }
    render();
  });

  incomeForm.addEventListener('submit', (e) => {
    e.preventDefault();
    const data = new FormData(incomeForm);
    const amount = Number.parseFloat(String(data.get('amount')).replace(',', '.'));
    if (!Number.isFinite(amount) || amount <= 0) {
      $<HTMLInputElement>('#income-amount').focus();
      return;
    }
    income = addIncome(house.id, {
      description: String(data.get('description')).trim(),
      amount: Math.round(amount * 100) / 100,
      type: String(data.get('type')) as 'sueldo' | 'extra',
      person: String(data.get('person')).trim(),
      date: String(data.get('date')) || todayISO(),
    });
    selectedMonth = monthKeyOf(String(data.get('date')) || todayISO());
    incomeForm.reset();
    $<HTMLInputElement>('#income-date').value = todayISO();
    personSelect.value = currentUser.displayName;
    if (isMobile()) {
      setView('movs');
    } else {
      $<HTMLInputElement>('#income-description').focus();
    }
    render();
  });

  fixedForm.addEventListener('submit', (e) => {
    e.preventDefault();
    const data = new FormData(fixedForm);
    const amount = Number.parseFloat(String(data.get('amount')).replace(',', '.'));
    if (!Number.isFinite(amount) || amount <= 0) {
      $<HTMLInputElement>('#fixed-amount').focus();
      return;
    }
    fixed = addFixedCost(house.id, {
      description: String(data.get('description')).trim(),
      amount: Math.round(amount * 100) / 100,
      category: String(data.get('category')) as CategoryId,
      paidBy: String(data.get('paidBy')).trim(),
    });
    fixedForm.reset();
    fixedPaidBySel.value = currentUser.displayName;
    if (!isMobile()) $<HTMLInputElement>('#fixed-description').focus();
    render();
  });

  for (const btn of [hideBtn, settingsHide]) {
    btn.addEventListener('click', () => {
      moneyHidden = !moneyHidden;
      localStorage.setItem(HIDE_KEY, moneyHidden ? '1' : '0');
      updateHideBtn();
      render();
    });
  }

  function updateHideBtn(): void {
    hideBtn.setAttribute('aria-pressed', String(moneyHidden));
    hideBtn.textContent = moneyHidden ? '🙈 Mostrar' : '👁️ Ocultar';
    hideBtn.title = moneyHidden ? 'Mostrar importes' : 'Ocultar importes';
    settingsHide.setAttribute('aria-pressed', String(moneyHidden));
    settingsHide.textContent = moneyHidden ? '🙈 Mostrar importes' : '👁️ Ocultar importes';
  }

  monthSelect.addEventListener('change', () => {
    selectedMonth = monthSelect.value;
    render();
  });

  // Otro integrante puede estar usando la app en otra pestaña de este navegador.
  window.addEventListener('storage', () => {
    const fresh = user ? getActiveHouse(user) : null;
    if (!fresh) {
      window.location.replace('/casa');
      return;
    }
    house = fresh;
    expenses = loadExpenses(house.id);
    fixed = loadFixedCosts(house.id);
    income = loadIncome(house.id);
    renderHouseHeader();
    populateMemberSelects();
    render();
  });

  dateInput.value = todayISO();
  $<HTMLInputElement>('#income-date').value = todayISO();
  $<HTMLSelectElement>('#category').value = CATEGORIES[0]!.id;
  $<HTMLSelectElement>('#fixed-category').value = CATEGORIES[0]!.id;
  $<HTMLSelectElement>('#income-type').value = INCOME_TYPES[0]!.id;
  updateHideBtn();
  renderHouseHeader();
  populateMemberSelects();
  render();
</script>

