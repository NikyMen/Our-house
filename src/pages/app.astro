  .income-item {
    background: rgba(16, 185, 129, 0.06);
    border-color: rgba(16, 185, 129, 0.25);
  }

  .income-item:hover {
    border-color: #10b981;
  }

  .income-dot {
    background: #10b981 !important;
  }

  .income-amount {
    color: #10b981;
  }

  .cat-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
  }

  /* ── Fila de costo fijo: incluye el toggle de "pagado" ── */
  .fixed-item {
    grid-template-columns: auto 1fr auto auto auto;
  }

  .fixed-item.fixed-paid {
    border-color: rgba(16, 185, 129, 0.4);
    background: rgba(16, 185, 129, 0.06);
  }

  .paid-toggle {
    white-space: nowrap;
    padding: 0.4rem 0.7rem;
    border-radius: 999px;
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--text-muted);
    font-size: 0.8rem;
    font-weight: 600;
    transition: border-color 0.15s ease, color 0.15s ease, background 0.15s ease;
  }

  .paid-toggle:hover {
    border-color: var(--accent);
    color: var(--text);
  }

  .paid-toggle.is-paid {
    border-color: rgba(16, 185, 129, 0.55);
    background: rgba(16, 185, 129, 0.15);
    color: #10b981;
  }

  .paid-toggle:disabled {
    opacity: 0.6;
    cursor: progress;
  }

  .expense-main {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  .expense-desc {
    font-weight: 600;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .expense-meta {
    color: var(--text-muted);
    font-size: 0.82rem;
  }

  .expense-amount {
    font-weight: 700;
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
  }

  .btn-del {
    background: transparent;
    border: none;
    color: var(--text-muted);
    font-size: 0.9rem;
    width: 28px;
    height: 28px;
    border-radius: 8px;
    display: grid;
    place-items: center;
    transition: background 0.15s ease, color 0.15s ease;
  }

  .btn-del:hover {
    background: rgba(239, 68, 68, 0.15);
    color: var(--danger);
  }

  .empty {
    text-align: center;
    color: var(--text-muted);
    padding: 2rem 1rem;
  }

  .foot {
    text-align: center;
    color: var(--text-muted);
    font-size: 0.82rem;
    margin-top: 0.5rem;
  }

  /* ── Fila de movimiento clickeable (abre el popup de edición) ── */
  .expense-item.is-clickable {
    cursor: pointer;
  }

  .expense-item.is-clickable::after {
    content: '›';
    color: var(--text-muted);
    font-size: 1.4rem;
    line-height: 1;
    justify-self: end;
    transition: color 0.15s ease;
  }

  .expense-item.is-clickable:hover::after,
  .expense-item.is-clickable:focus-visible::after {
    color: var(--accent);
  }

  .expense-item.is-clickable:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  /* ── Popup de edición de movimientos ── */
  .modal-backdrop {
    position: fixed;
    inset: 0;
    z-index: 100;
    display: grid;
    place-items: center;
    padding: 1rem;
    background: rgba(2, 6, 23, 0.65);
    -webkit-backdrop-filter: blur(4px);
    backdrop-filter: blur(4px);
  }

  .modal-backdrop[hidden] {
    display: none;
  }

  .modal {
    width: 100%;
    max-width: 440px;
    max-height: calc(100dvh - 2rem);
    overflow-y: auto;
  }

  .modal-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1rem;
  }

  .modal-head h2 {
    font-size: 1.2rem;
    margin: 0;
  }

  .modal-close {
    background: transparent;
    border: none;
    color: var(--text-muted);
    font-size: 1.1rem;
    width: 34px;
    height: 34px;
    border-radius: 8px;
    flex-shrink: 0;
  }

  .modal-close:hover {
    background: var(--surface-2);
    color: var(--text);
  }

  .modal-actions {
    display: flex;
    gap: 0.75rem;
    margin-top: 1.2rem;
  }

  .modal-actions .btn-primary {
    margin-top: 0;
    flex: 1;
  }

  .btn-delete {
    padding: 0.75rem 1.1rem;
    border: 1px solid rgba(239, 68, 68, 0.5);
    border-radius: 10px;
    background: transparent;
    color: var(--danger);
    font-weight: 600;
    transition: background 0.15s ease;
  }

  .btn-delete:hover {
    background: rgba(239, 68, 68, 0.12);
  }

  :global(body.modal-open) {
    overflow: hidden;
  }

  /* ═══════════ Mobile: elementos base (ocultos en desktop) ═══════════ */

  .only-mobile {
    display: none;
  }

  /* ── Switch Gasto / Ingreso (vista Añadir) ── */
  .add-switch {
    display: none;
    grid-template-columns: 1fr 1fr;
    gap: 0.35rem;
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 0.3rem;
  }

  .add-tab {
    border: none;
    background: transparent;
    color: var(--text-muted);
    padding: 0.65rem 0.5rem;
    border-radius: 9px;
    font-weight: 600;
    transition: background 0.15s ease, color 0.15s ease;
  }

  .add-tab.active {
    background: var(--accent);
    color: white;
  }

  .add-tab.active[data-mode='ingreso'] {
    background: #10b981;
  }

  /* ── Tarjeta de Ajustes (solo mobile) ── */
  .settings-card {
    display: none;
    flex-direction: column;
    gap: 1.1rem;
  }

  .settings-card h2 {
    font-size: 1.15rem;
  }

  .settings-user {
    margin: -0.75rem 0 0;
    color: var(--text-muted);
    font-size: 0.9rem;
  }

  .settings-label {
    display: block;
    color: var(--text-muted);
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.4rem;
  }

  .settings-house-name {
    margin: 0;
    font-weight: 650;
    font-size: 1.05rem;
  }

  .settings-house-members {
    margin: 0.15rem 0 0;
    color: var(--text-muted);
    font-size: 0.85rem;
  }

  .settings-code-row {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  .settings-code {
    font-size: 1.2rem;
    padding: 0.45rem 0.8rem;
  }

  .settings-copy {
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: 10px;
    color: var(--text);
    padding: 0.55rem 0.9rem;
    font-weight: 600;
  }

  .settings-actions {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .settings-btn {
    display: block;
    width: 100%;
    text-align: center;
    background: var(--surface-2);
    border: 1px solid var(--border);
    color: var(--text);
    padding: 0.85rem 1rem;
    border-radius: 12px;
    font-weight: 600;
    text-decoration: none;
    transition: border-color 0.15s ease, color 0.15s ease;
  }

  .settings-btn[aria-pressed='true'] {
    border-color: var(--accent);
    color: var(--accent-hover);
  }

  .settings-danger {
    color: var(--danger);
    border-color: rgba(239, 68, 68, 0.4);
  }

  .settings-note {
    margin: 0;
    color: var(--text-muted);
    font-size: 0.78rem;
  }

  /* ── Nav inferior ── */
  .mobile-nav {
    position: fixed;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 50;
    display: none;
    grid-template-columns: 1fr 1fr 72px 1fr 1fr;
    align-items: end;
    background: rgba(15, 23, 42, 0.92);
    -webkit-backdrop-filter: blur(14px);
    backdrop-filter: blur(14px);
    border-top: 1px solid var(--border);
    padding: 0.4rem 0.4rem calc(0.45rem + env(safe-area-inset-bottom));
  }

  .nav-item {
    background: none;
    border: none;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.15rem;
    color: var(--text-muted);
    font-size: 0.66rem;
    font-weight: 600;
    padding: 0.3rem 0;
    border-radius: 10px;
    transition: color 0.15s ease;
  }

  .nav-icon {
    font-size: 1.35rem;
    line-height: 1;
  }

  .nav-item.active {
    color: var(--accent-hover);
  }

  .nav-fab {
    width: 54px;
    height: 54px;
    margin: -1.6rem auto 0;
    border: none;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--accent) 0%, #8b5cf6 100%);
    color: white;
    font-size: 1.7rem;
    line-height: 1;
    display: grid;
    place-items: center;
    box-shadow: 0 10px 24px rgba(99, 102, 241, 0.5);
    transition: transform 0.15s ease, outline 0.15s ease;
  }

  .nav-fab:active {
    transform: scale(0.94);
  }

  .nav-fab.active {
    outline: 3px solid rgba(129, 140, 248, 0.45);
  }

  /* ═══════════ Desktop: layout por secciones ═══════════ */

  @media (min-width: 821px) {
    .page[data-desktop-view='gastos'] .card-income,
    .page[data-desktop-view='gastos'] .card-fixed,
    .page[data-desktop-view='ingresos'] .card-expense,
    .page[data-desktop-view='ingresos'] .card-fixed,
    .page[data-desktop-view='fijos'] .card-expense,
    .page[data-desktop-view='fijos'] .card-income,
    .page[data-desktop-view='fijos'] .list-card {
      display: none;
    }

    /* En Costos fijos no hay lista de movimientos al lado: la tarjeta
       (form + lista propia) ocupa todo el ancho de la página. */
    .page[data-desktop-view='fijos'] .layout-grid {
      grid-template-columns: 1fr;
    }
  }

  /* ═══════════ Mobile: layout por vistas ═══════════ */

  @media (max-width: 820px) {
    .page {
      gap: 1rem;
      padding: 0.9rem 0.9rem calc(92px + env(safe-area-inset-bottom));
    }

    /* Header compacto: solo marca + selector de mes */
    .house-chip,
    .user-area,
    .btn-hide,
    .desktop-nav {
      display: none;
    }

    .logo {
      font-size: 1.9rem;
    }

    .brand h1 {
      font-size: 1.25rem;
    }

    .tagline {
      font-size: 0.78rem;
    }

    .header-right {
      margin-left: auto;
    }

    .month-pick label {
      display: none;
    }

    .month-pick select {
      min-width: 0;
    }

    .summary {
      grid-template-columns: 1fr;
    }

    .layout-grid {
      grid-template-columns: 1fr;
    }

    /* Cada pestaña de la nav muestra una sola vista */
    .summary,
    .list-card,
    .card-expense,
    .card-income,
    .card-fixed,
    .foot,
    .only-desktop {
      display: none;
    }

    .only-mobile {
      display: inline;
    }

    .page[data-view='resumen'] .summary {
      display: grid;
    }

    .page[data-view='movs'] .list-card {
      display: block;
    }

    .page[data-view='add'] .add-switch {
      display: grid;
    }

    .page[data-view='add'][data-add-mode='gasto'] .card-expense {
      display: block;
    }

    .page[data-view='add'][data-add-mode='ingreso'] .card-income {
      display: block;
    }

    .page[data-view='fijos'] .card-fixed {
      display: block;
    }

    .page[data-view='ajustes'] .settings-card {
      display: flex;
    }

    .mobile-nav {
      display: grid;
    }

    /* Ergonomía táctil */
    .total-value {
      font-size: 2.5rem;
    }

    .btn-del {
      width: 38px;
      height: 38px;
      font-size: 1rem;
    }

    /* Filas de movimientos: en pantallas angostas la descripción
       envuelve en vez de truncarse. */
    .expense-item {
      gap: 0.6rem;
      padding: 0.7rem;
    }

    .expense-desc {
      white-space: normal;
      overflow-wrap: anywhere;
    }

    /* Costo fijo en mobile: el toggle de pagado va en una fila propia. */
    .fixed-item {
      grid-template-columns: auto 1fr auto auto;
    }

    .fixed-item .paid-toggle {
      grid-column: 1 / -1;
      justify-self: start;
    }
  }

  /* ═══════════════════════════════════════════════════════════════════
     SKIN GLASSMORPHISM — superficies de vidrio, brillos y animaciones.
     Va al final del bloque para pisar la piel anterior sin tocar el layout.
     ═══════════════════════════════════════════════════════════════════ */

  .card {
    background: var(--glass-bg);
    -webkit-backdrop-filter: var(--glass-filter);
    backdrop-filter: var(--glass-filter);
    border: 1px solid var(--glass-border);
    box-shadow: var(--glass-shadow);
    transition: border-color 0.25s ease, box-shadow 0.25s ease, transform 0.25s ease;
  }

  .summary .card:hover,
  .stat-tile:hover,
  .chart-card:hover {
    border-color: var(--glass-border-hover);
    transform: translateY(-2px);
    box-shadow: 0 24px 48px -20px rgba(2, 6, 23, 0.75), inset 0 1px 0 rgba(255, 255, 255, 0.12);
  }

  .desktop-nav {
    background: var(--glass-bg);
    -webkit-backdrop-filter: var(--glass-filter);
    backdrop-filter: var(--glass-filter);
    border: 1px solid var(--glass-border);
    box-shadow: var(--glass-shadow);
  }

  .house-chip {
    background: rgba(255, 255, 255, 0.05);
    border-color: var(--glass-border);
    -webkit-backdrop-filter: blur(10px);
    backdrop-filter: blur(10px);
  }

  .house-code {
    background: rgba(7, 11, 26, 0.55);
    border-color: rgba(148, 163, 197, 0.35);
  }

  .logo {
    display: inline-block;
    animation: logo-float 5.5s ease-in-out infinite;
  }

  @keyframes logo-float {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-5px);
    }
  }

  .btn-primary {
    background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
    border-radius: 12px;
    box-shadow: 0 12px 26px -12px rgba(99, 102, 241, 0.85), inset 0 1px 0 rgba(255, 255, 255, 0.22);
    transition: transform 0.15s ease, box-shadow 0.2s ease, filter 0.2s ease;
  }

  .btn-primary:hover {
    background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
    filter: brightness(1.12);
    transform: translateY(-1px);
    box-shadow: 0 16px 32px -12px rgba(99, 102, 241, 1), inset 0 1px 0 rgba(255, 255, 255, 0.22);
  }

  .btn-income {
    background: linear-gradient(135deg, #10b981 0%, #059669 100%);
    border-radius: 12px;
    box-shadow: 0 12px 26px -12px rgba(16, 185, 129, 0.8), inset 0 1px 0 rgba(255, 255, 255, 0.22);
    transition: transform 0.15s ease, box-shadow 0.2s ease, filter 0.2s ease;
  }

  .btn-income:hover {
    background: linear-gradient(135deg, #10b981 0%, #059669 100%);
    filter: brightness(1.1);
    transform: translateY(-1px);
  }

  /* ── Tarjeta de saldo: vidrio esmeralda con brillo que barre ── */
  .saldo-card {
    position: relative;
    overflow: hidden;
    background: linear-gradient(135deg, rgba(16, 185, 129, 0.62) 0%, rgba(4, 120, 87, 0.5) 100%);
    -webkit-backdrop-filter: var(--glass-filter);
    backdrop-filter: var(--glass-filter);
    border: 1px solid rgba(110, 231, 183, 0.35);
    box-shadow: 0 18px 44px -16px rgba(16, 185, 129, 0.4), inset 0 1px 0 rgba(255, 255, 255, 0.2);
  }

  .saldo-card.saldo-negative {
    background: linear-gradient(135deg, rgba(239, 68, 68, 0.6) 0%, rgba(153, 27, 27, 0.48) 100%);
    border-color: rgba(252, 165, 165, 0.35);
    box-shadow: 0 18px 44px -16px rgba(239, 68, 68, 0.4), inset 0 1px 0 rgba(255, 255, 255, 0.18);
  }

  .saldo-shine {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: linear-gradient(
      115deg,
      transparent 32%,
      rgba(255, 255, 255, 0.16) 46%,
      rgba(255, 255, 255, 0.03) 55%,
      transparent 70%
    );
    transform: translateX(-130%);
    animation: shine-swipe 7s ease-in-out infinite;
  }

  @keyframes shine-swipe {
    0% {
      transform: translateX(-130%);
    }
    55%,
    100% {
      transform: translateX(130%);
    }
  }

  .saldo-spark {
    margin-top: 0.55rem;
    height: 34px;
  }

  .saldo-spark :global(.spark-svg) {
    width: min(100%, 190px);
    height: 100%;
    display: block;
  }

  .saldo-spark :global(.spark-line) {
    fill: none;
    stroke: rgba(255, 255, 255, 0.78);
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
    transition: stroke-dashoffset 1.1s cubic-bezier(0.4, 0, 0.2, 1) 0.2s;
  }

  .saldo-spark :global(.spark-dot) {
    fill: #fff;
  }

  .saldo-spark :global(.spark-zero) {
    stroke: rgba(255, 255, 255, 0.3);
    stroke-width: 1;
  }

  /* ── Dona por categoría ── */
  .cat-flex {
    display: flex;
    align-items: center;
    gap: 1.1rem;
  }

  .donut-wrap {
    position: relative;
    width: 168px;
    height: 168px;
    flex: none;
  }

  .donut-shimmer {
    position: absolute;
    inset: 8px;
    border-radius: 50%;
  }

  .donut-wrap :global(.donut-svg) {
    width: 100%;
    height: 100%;
    display: block;
  }

  .donut-wrap :global(.donut-seg) {
    transition: stroke-dasharray 0.9s cubic-bezier(0.22, 1, 0.36, 1), stroke-width 0.2s ease;
    cursor: pointer;
    outline: none;
  }

  .donut-wrap :global(.donut-seg.is-hot),
  .donut-wrap :global(.donut-seg:focus-visible) {
    stroke-width: 20;
  }

  .donut-wrap :global(.donut-center) {
    position: absolute;
    inset: 0;
    display: grid;
    place-content: center;
    text-align: center;
    gap: 0.05rem;
    pointer-events: none;
  }

  .donut-wrap :global(.donut-center strong) {
    font-size: 1.3rem;
    letter-spacing: -0.02em;
  }

  .donut-wrap :global(.donut-center span) {
    color: var(--text-muted);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.07em;
  }

  .cat-breakdown {
    flex: 1;
    min-width: 0;
    max-height: 190px;
    overflow-y: auto;
    padding-right: 0.3rem;
  }

  /* ── Filas de desglose con micro-barra ── */
  .breakdown :global(.b-row) {
    display: flex;
    flex-direction: column;
    gap: 0.28rem;
  }

  .breakdown :global(.b-top) {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 0.75rem;
    font-size: 0.9rem;
  }

  .breakdown :global(.b-right) {
    display: inline-flex;
    align-items: baseline;
    gap: 0.45rem;
    flex: none;
  }

  .breakdown :global(.b-pct) {
    color: var(--text-muted);
    font-size: 0.74rem;
    min-width: 2.5em;
    text-align: right;
    font-variant-numeric: tabular-nums;
  }

  .breakdown :global(.b-bar) {
    height: 6px;
    border-radius: 999px;
    background: rgba(148, 163, 197, 0.13);
    overflow: hidden;
  }

  .breakdown :global(.b-bar-fill) {
    display: block;
    height: 100%;
    width: 0;
    border-radius: 999px;
    transition: width 0.8s cubic-bezier(0.22, 1, 0.36, 1);
  }

  /* ── Sección de estadísticas ── */
  .stats {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .stats-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    padding: 0 0.15rem;
  }

  .stats-head h2 {
    font-size: 1.25rem;
  }

  .kpi-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
  }

  .stat-tile {
    padding: 1.05rem 1.2rem;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .stat-label {
    color: var(--text-muted);
    font-size: 0.74rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .stat-value {
    font-size: 1.5rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.15;
  }

  .stat-hint {
    color: var(--text-muted);
    font-size: 0.8rem;
  }

  /* Estado (dirección del gasto): color + flecha, nunca color solo. */
  .stat-delta.delta-up {
    color: #f87171;
  }

  .stat-delta.delta-down {
    color: #34d399;
  }

  .meter {
    height: 8px;
    border-radius: 999px;
    background: rgba(148, 163, 197, 0.16);
    overflow: hidden;
    margin: 0.15rem 0;
  }

  .meter-fill {
    display: block;
    height: 100%;
    width: 0;
    border-radius: 999px;
    transition: width 0.9s cubic-bezier(0.22, 1, 0.36, 1), background 0.3s ease;
  }

  :global(.meter-fill.meter-ok) {
    background: linear-gradient(90deg, #059669, #34d399);
  }

  :global(.meter-fill.meter-warn) {
    background: linear-gradient(90deg, #b45309, #f59e0b);
  }

