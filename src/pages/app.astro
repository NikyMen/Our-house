        const nextPaid = !fixedPaid.has(key);
        // Actualización optimista; se revierte si la API falla.
        applyToggleState(nextPaid);
        toggle.disabled = true;
        try {
          await apiSetFixedPaid(f.id, selectedMonth, nextPaid);
          if (nextPaid) fixedPaid.add(key);
