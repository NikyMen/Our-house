  /* ── Números que cuentan: animación de valor con easing ── */
  const numAnims = new WeakMap<HTMLElement, number>();
  const numValues = new WeakMap<HTMLElement, number>();

  function animateNumber(el: HTMLElement, to: number, fmt: (v: number) => string): void {
    const prev = numAnims.get(el);
    if (prev) cancelAnimationFrame(prev);
    if (moneyHidden || REDUCED_MOTION) {
      numValues.set(el, to);
      el.textContent = fmt(to);
      return;
    }
    const from = numValues.get(el) ?? 0;
    if (from === to) {
      el.textContent = fmt(to);
      return;
    }
    const t0 = performance.now();
    const dur = 750;
    const tick = (now: number): void => {
      const t = Math.min(1, (now - t0) / dur);
      const eased = 1 - Math.pow(1 - t, 3);
      el.textContent = fmt(from + (to - from) * eased);
      if (t < 1) {
        numAnims.set(el, requestAnimationFrame(tick));
      } else {
        numValues.set(el, to);
      }
    };
    numAnims.set(el, requestAnimationFrame(tick));
  }

