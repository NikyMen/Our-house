      ...monthly.map((e) => ({ kind: 'expense' as const, date: e.date, id: e.id })),
      ...monthIncome.map((i) => ({ kind: 'income' as const, date: i.date, id: i.id })),
    ].sort((a, b) => b.date.localeCompare(a.date));

    const expenseMap = new Map(monthly.map((e) => [e.id, e]));
