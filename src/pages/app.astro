---
import Layout from '../layouts/Layout.astro';
import { CATEGORIES, INCOME_TYPES } from '../lib/types';
import { getActiveHouse, loadExpenses, loadFixedCosts, loadFixedPayments, loadIncome } from '../lib/db';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/');
const house = await getActiveHouse(user);
if (!house) return Astro.redirect('/casa');

const [expenses, fixed, income, fixedPaid] = await Promise.all([
  loadExpenses(house.id),
  loadFixedCosts(house.id),
  loadIncome(house.id),
  loadFixedPayments(house.id),
]);
const initialData = { user, house, expenses, fixed, income, fixedPaid };
---

<Layout title="OurHouse · App">
  <script id="__DATA__" type="application/json" is:inline set:html={JSON.stringify(initialData)}
  ></script>
  <div class="page" id="page" data-view="resumen" data-add-mode="gasto" data-desktop-view="gastos">
    <header class="header">
      <div class="brand">
        <span class="logo">🏠</span>
        <div>
          <h1>OurHouse</h1>
          <p id="house-tagline" class="tagline">Gastos del hogar</p>
        </div>
      </div>
      <div class="header-right">
        <div class="house-chip" title="Código de invitación de la casa">
          <span class="house-chip-label">Invitar:</span>
          <code id="house-code" class="house-code"></code>
          <button id="copy-code-btn" class="btn-copy" type="button" title="Copiar código de invitación">📋</button>
          <a class="btn-house" href="/casa?elegir=1">Cambiar casa</a>
        </div>
        <div class="month-pick">
          <label for="month-select">Mes</label>
          <button id="month-prev" class="month-arrow" type="button" aria-label="Mes anterior">‹</button>
          <select id="month-select" aria-label="Seleccionar mes"></select>
          <button id="month-next" class="month-arrow" type="button" aria-label="Mes siguiente">›</button>
        </div>
        <button id="hide-btn" class="btn-hide" type="button" aria-pressed="false" title="Ocultar importes">
          👁️ Ocultar
        </button>
        <div class="user-area">
          <span id="user-greeting" class="user-greeting"></span>
          <button id="logout-btn" class="btn-logout" type="button">Salir</button>
        </div>
      </div>
    </header>

    <nav class="desktop-nav" role="tablist" aria-label="Secciones principales">
      <button type="button" class="desktop-tab active" data-dview="gastos" role="tab" aria-selected="true">
        <span class="dtab-icon">💸</span>
        <span class="dtab-text">
          <span class="dtab-label">Gastos</span>
          <span class="dtab-sub" id="dtab-sub-gastos">—</span>
        </span>
      </button>
      <button type="button" class="desktop-tab" data-dview="ingresos" role="tab" aria-selected="false">
        <span class="dtab-icon">💰</span>
        <span class="dtab-text">
          <span class="dtab-label">Ingresos</span>
          <span class="dtab-sub" id="dtab-sub-ingresos">—</span>
        </span>
      </button>
      <button type="button" class="desktop-tab" data-dview="fijos" role="tab" aria-selected="false">
        <span class="dtab-icon">📌</span>
        <span class="dtab-text">
          <span class="dtab-label">Costos fijos</span>
          <span class="dtab-sub" id="dtab-sub-fijos">—</span>
        </span>
      </button>
    </nav>

    <section class="summary">
      <article class="card saldo-card" id="saldo-card">
        <span class="saldo-shine" aria-hidden="true"></span>
        <span class="card-label">Saldo del mes</span>
        <strong id="saldo-value" class="total-value">—</strong>
        <span id="saldo-hint" class="card-hint"></span>
        <div class="saldo-spark" id="saldo-spark" title="Saldo de los últimos 6 meses"></div>
      </article>
      <article class="card cat-card">
        <span class="card-label">Por categoría</span>
        <div class="cat-flex">
          <div class="donut-wrap" id="donut-wrap">
            <div class="shimmer donut-shimmer"></div>
          </div>
          <ul id="by-category" class="breakdown cat-breakdown"></ul>
        </div>
      </article>
      <article class="card">
        <span class="card-label">Quién pagó</span>
        <ul id="by-person" class="breakdown person-breakdown"></ul>
      </article>
    </section>

    <section class="stats" id="stats" aria-label="Estadísticas del mes">
      <div class="stats-head">
        <h2>📈 Estadísticas</h2>
        <span id="stats-sub" class="card-hint"></span>
      </div>

      <div class="kpi-row">
        <article class="card stat-tile">
          <span class="stat-label">Promedio diario</span>
          <strong class="stat-value" id="kpi-avg">—</strong>
          <span class="stat-hint" id="kpi-avg-hint"></span>
        </article>
        <article class="card stat-tile">
          <span class="stat-label" id="kpi-proj-label">Proyección del mes</span>
          <strong class="stat-value" id="kpi-proj">—</strong>
          <span class="stat-hint" id="kpi-proj-hint"></span>
        </article>
        <article class="card stat-tile">
          <span class="stat-label">Gastos vs mes anterior</span>
          <strong class="stat-value stat-delta" id="kpi-delta">—</strong>
          <span class="stat-hint" id="kpi-delta-hint"></span>
        </article>
        <article class="card stat-tile">
          <span class="stat-label">Tasa de ahorro</span>
          <strong class="stat-value" id="kpi-save">—</strong>
          <div class="meter" id="kpi-save-meter" hidden>
            <span class="meter-fill" id="kpi-save-fill"></span>
          </div>
          <span class="stat-hint" id="kpi-save-hint"></span>
        </article>
      </div>

      <div class="charts-grid">
        <article class="card chart-card">
          <div class="chart-head">
            <h3>Gasto acumulado del mes</h3>
            <div class="chart-legend" aria-hidden="true">
              <span class="lg-item"><i class="lg-line" style="background:var(--chart-gasto)"></i>Este mes</span>
              <span class="lg-item" id="lg-prev"><i class="lg-line" style="background:var(--chart-context)"></i>Mes anterior</span>
            </div>
          </div>
          <div class="chart-body" id="chart-cum">
            <div class="shimmer chart-shimmer"></div>
          </div>
          <details class="chart-table">
            <summary>Ver datos</summary>
            <div class="chart-table-scroll"><table id="table-cum"></table></div>
          </details>
        </article>

        <article class="card chart-card">
          <div class="chart-head">
            <h3>Últimos 6 meses</h3>
            <div class="chart-legend" aria-hidden="true">
              <span class="lg-item"><i class="lg-swatch" style="background:var(--chart-gasto)"></i>Gastos</span>
              <span class="lg-item"><i class="lg-swatch" style="background:var(--chart-ingreso)"></i>Ingresos</span>
            </div>
          </div>
          <div class="chart-body" id="chart-months">
            <div class="shimmer chart-shimmer"></div>
          </div>
          <details class="chart-table">
            <summary>Ver datos</summary>
            <div class="chart-table-scroll"><table id="table-months"></table></div>
          </details>
        </article>
      </div>
    </section>

    <section class="layout-grid">
      <div class="form-col">
        <div class="add-switch" role="tablist" aria-label="Tipo de movimiento">
          <button type="button" class="add-tab active" data-mode="gasto" role="tab" aria-selected="true">
            💸 Gasto
          </button>
          <button type="button" class="add-tab" data-mode="ingreso" role="tab" aria-selected="false">
            💰 Ingreso
          </button>
        </div>

        <aside class="card form-card card-expense">
          <h2>Nuevo gasto</h2>
          <form id="expense-form" autocomplete="off">
            <div class="field">
              <label for="description">Descripción <span class="field-optional">(opcional)</span></label>
              <input id="description" name="description" type="text" placeholder="Compra semanal" maxlength="80" />
            </div>
            <div class="field-row">
              <div class="field">
                <label for="amount">Importe ($)</label>
                <input id="amount" name="amount" type="number" inputmode="decimal" step="0.01" min="0.01" placeholder="0,00" required />
              </div>
              <div class="field">
                <label for="date">Fecha</label>
                <input id="date" name="date" type="date" required />
              </div>
            </div>
            <div class="field-row">
              <div class="field">
                <label for="category">Categoría</label>
                <select id="category" name="category">
                  {CATEGORIES.map((c) => <option value={c.id}>{c.emoji} {c.label}</option>)}
                </select>
              </div>
              <div class="field">
                <label for="paidBy">Pagado por</label>
                <select id="paidBy" name="paidBy" required></select>
              </div>
            </div>
            <button type="submit" class="btn-primary">Añadir gasto</button>
          </form>
        </aside>

        <aside class="card form-card income-form-card card-income">
          <div class="list-head">
            <h2>Cargar saldo</h2>
            <span id="income-month-total" class="card-hint"></span>
          </div>
          <form id="income-form" autocomplete="off">
            <div class="field">
              <label for="income-description">Descripción</label>
              <input id="income-description" name="description" type="text" placeholder="Sueldo julio, trabajo extra…" required maxlength="80" />
            </div>
            <div class="field-row">
              <div class="field">
                <label for="income-amount">Importe ($)</label>
                <input id="income-amount" name="amount" type="number" inputmode="decimal" step="0.01" min="0.01" placeholder="0,00" required />
              </div>
              <div class="field">
                <label for="income-date">Fecha</label>
                <input id="income-date" name="date" type="date" required />
              </div>
            </div>
            <div class="field-row">
              <div class="field">
                <label for="income-type">Tipo</label>
                <select id="income-type" name="type">
                  {INCOME_TYPES.map((t) => <option value={t.id}>{t.emoji} {t.label}</option>)}
                </select>
              </div>
              <div class="field">
                <label for="income-person">Persona</label>
                <select id="income-person" name="person" required></select>
              </div>
            </div>
            <button type="submit" class="btn-income">Añadir ingreso</button>
          </form>
        </aside>

        <aside class="card form-card card-fixed">
          <div class="list-head">
            <h2>Costos fijos</h2>
            <span id="fixed-total" class="card-hint"></span>
          </div>
          <p class="fixed-help">Se suman automáticamente todos los meses.</p>
          <form id="fixed-form" autocomplete="off">
            <div class="field">
              <label for="fixed-description">Descripción</label>
              <input id="fixed-description" name="description" type="text" placeholder="Alquiler, internet…" required maxlength="80" />
            </div>
            <div class="field-row">
              <div class="field">
                <label for="fixed-amount">Importe ($)</label>
                <input id="fixed-amount" name="amount" type="number" inputmode="decimal" step="0.01" min="0.01" placeholder="0,00" required />
              </div>
              <div class="field">
                <label for="fixed-category">Categoría</label>
                <select id="fixed-category" name="category">
                  {CATEGORIES.map((c) => <option value={c.id}>{c.emoji} {c.label}</option>)}
                </select>
              </div>
            </div>
            <div class="field">
              <label for="fixed-paidBy">Pagado por</label>
              <select id="fixed-paidBy" name="paidBy" required></select>
            </div>
            <button type="submit" class="btn-primary">Añadir costo fijo</button>
          </form>
          <ul id="fixed-list" class="expense-list fixed-list"></ul>
          <p id="fixed-empty" class="empty" hidden>Sin costos fijos todavía.</p>
        </aside>
      </div>

      <section class="card list-card">
        <div class="list-head">
          <h2>Movimientos</h2>
          <span id="list-count" class="card-hint"></span>
        </div>
        <ul id="expense-list" class="expense-list"></ul>
        <p id="empty-state" class="empty" hidden>
          Todavía no hay movimientos este mes.
          <span class="only-desktop">¡Cargá tu saldo o añadí un gasto! 👈</span>
          <span class="only-mobile">Tocá el botón ➕ para cargar tu saldo o añadir un gasto.</span>
        </p>
      </section>
    </section>

    <section class="card settings-card" aria-label="Ajustes">
      <h2>Ajustes</h2>
      <p id="settings-user" class="settings-user"></p>

      <div class="settings-block">
        <span class="settings-label">Casa actual</span>
        <p id="settings-house-name" class="settings-house-name"></p>
        <p id="settings-house-members" class="settings-house-members"></p>
      </div>

      <div class="settings-block">
        <span class="settings-label">Código de invitación</span>
        <div class="settings-code-row">
          <code id="settings-house-code" class="house-code settings-code"></code>
          <button id="settings-copy-btn" class="settings-copy" type="button">📋 Copiar</button>
        </div>
      </div>

      <div class="settings-actions">
        <a class="settings-btn" href="/casa?elegir=1">🔁 Cambiar de casa</a>
        <button id="settings-hide-btn" class="settings-btn" type="button" aria-pressed="false">
          👁️ Ocultar importes
        </button>
        <button id="settings-logout-btn" class="settings-btn settings-danger" type="button">
          🚪 Cerrar sesión
        </button>
      </div>

      <p class="settings-note">
        Los datos de cada casa se guardan solo en este navegador (localStorage).
        Compartí el código de invitación para que los demás se unan desde este mismo navegador.
      </p>
    </section>

    <footer class="foot">
      Los datos de la casa se guardan en el servidor.
      Compartí el código de invitación para que los demás se unan desde cualquier dispositivo.
    </footer>
  </div>

  <nav class="mobile-nav" aria-label="Navegación principal">
    <button class="nav-item active" type="button" data-view="resumen">
      <span class="nav-icon">📊</span>
      <span>Resumen</span>
    </button>
    <button class="nav-item" type="button" data-view="movs">
      <span class="nav-icon">🧾</span>
      <span>Movim.</span>
    </button>
    <button class="nav-fab" type="button" data-view="add" aria-label="Añadir gasto o ingreso">＋</button>
    <button class="nav-item" type="button" data-view="fijos">
      <span class="nav-icon">📌</span>
      <span>Fijos</span>
    </button>
    <button class="nav-item" type="button" data-view="ajustes">
      <span class="nav-icon">⚙️</span>
      <span>Ajustes</span>
    </button>
  </nav>

  <div class="modal-backdrop" id="edit-modal" hidden>
    <div class="modal card" role="dialog" aria-modal="true" aria-labelledby="edit-modal-title">
      <div class="modal-head">
        <h2 id="edit-modal-title">Editar movimiento</h2>
        <button class="modal-close" id="edit-close" type="button" aria-label="Cerrar">✕</button>
      </div>
      <form id="edit-form" autocomplete="off">
        <div class="field">
          <label for="edit-description">Descripción</label>
          <input id="edit-description" name="description" type="text" required maxlength="80" />
        </div>
        <div class="field-row">
          <div class="field">
            <label for="edit-amount">Importe ($)</label>
            <input id="edit-amount" name="amount" type="number" inputmode="decimal" step="0.01" min="0.01" placeholder="0,00" required />
          </div>
          <div class="field">
            <label for="edit-date">Fecha</label>
            <input id="edit-date" name="date" type="date" required />
          </div>
        </div>
        <div class="field-row" id="edit-expense-fields">
          <div class="field">
            <label for="edit-category">Categoría</label>
            <select id="edit-category" name="category">
              {CATEGORIES.map((c) => <option value={c.id}>{c.emoji} {c.label}</option>)}
            </select>
          </div>
          <div class="field">
            <label for="edit-paidBy">Pagado por</label>
            <select id="edit-paidBy" name="paidBy"></select>
          </div>
        </div>
        <div class="field-row" id="edit-income-fields" hidden>
          <div class="field">
            <label for="edit-type">Tipo</label>
            <select id="edit-type" name="type">
              {INCOME_TYPES.map((t) => <option value={t.id}>{t.emoji} {t.label}</option>)}
            </select>
          </div>
          <div class="field">
            <label for="edit-person">Persona</label>
            <select id="edit-person" name="person"></select>
          </div>
        </div>
        <div class="modal-actions">
          <button type="button" class="btn-delete" id="edit-delete">🗑️ Eliminar</button>
          <button type="submit" class="btn-primary" id="edit-save">Guardar cambios</button>
        </div>
      </form>
    </div>
  </div>

  <template id="expense-row-tpl">
    <li class="expense-item">
      <span class="cat-dot"></span>
      <div class="expense-main">
        <span class="expense-desc"></span>
        <span class="expense-meta"></span>
      </div>
      <span class="expense-amount"></span>
      <button class="btn-del" type="button" aria-label="Eliminar gasto" title="Eliminar">✕</button>
    </li>
  </template>

  <template id="income-row-tpl">
    <li class="expense-item income-item">
      <span class="cat-dot income-dot"></span>
      <div class="expense-main">
        <span class="expense-desc"></span>
        <span class="expense-meta"></span>
      </div>
      <span class="expense-amount income-amount"></span>
      <button class="btn-del" type="button" aria-label="Eliminar ingreso" title="Eliminar">✕</button>
    </li>
  </template>

  <template id="fixed-row-tpl">
    <li class="expense-item fixed-item">
      <span class="cat-dot"></span>
      <div class="expense-main">
        <span class="expense-desc"></span>
        <span class="expense-meta"></span>
      </div>
      <button class="paid-toggle" type="button" aria-pressed="false"></button>
      <span class="expense-amount"></span>
      <button class="btn-del" type="button" aria-label="Eliminar costo fijo" title="Eliminar">✕</button>
    </li>
  </template>
</Layout>

<script>
  import {
    apiAddExpense,
    apiAddFixedCost,
    apiAddIncome,
    apiDeleteExpense,
    apiDeleteFixedCost,
    apiDeleteIncome,
    apiUpdateExpense,
    apiUpdateIncome,
    apiSetFixedPaid,
    apiLogout,
  } from '../lib/api-client';
  import {
    availableMonths,
    cumulativeByDay,
    donutSlices,
    filterByMonth,
    filterIncomeByMonth,
    fixedAsExpenses,
    fixedCostsTotal,
    incomeTotal,
    monthlySeries,
    total,
    totalsByCategory,
    totalsByPerson,
    type MonthlyPoint,
  } from '../lib/calc';
  import { CATEGORIES, INCOME_TYPES, SHARED_PAYER, getCategory, type CategoryId } from '../lib/types';
  import type { Expense, FixedCost, FixedPayment, House, Income, User } from '../lib/types';
  import {
    daysInMonth,
    formatDate,
    formatMonth,
    formatMoney,
    formatMoneyCompact,
    formatMonthShort,
    monthKeyOf,
    shiftMonth,
    todayISO,
  } from '../lib/format';

  // El servidor ya validó sesión y casa activa, e inyectó los datos iniciales.
  const data = JSON.parse(document.getElementById('__DATA__')!.textContent!) as {
    user: User;
    house: House;
    expenses: Expense[];
    fixed: FixedCost[];
    income: Income[];
    fixedPaid: FixedPayment[];
  };
  const currentUser = data.user;
  let house = data.house;

  const $ = <T extends HTMLElement>(sel: string): T => {
    const el = document.querySelector<T>(sel);
    if (!el) throw new Error(`No se encontró ${sel}`);
    return el;
  };

  const form           = $<HTMLFormElement>('#expense-form');
  const monthSelect    = $<HTMLSelectElement>('#month-select');
  const list           = $<HTMLUListElement>('#expense-list');
  const emptyState     = $<HTMLParagraphElement>('#empty-state');
  const rowTpl         = $<HTMLTemplateElement>('#expense-row-tpl');
  const incomeRowTpl   = $<HTMLTemplateElement>('#income-row-tpl');
  const fixedRowTpl    = $<HTMLTemplateElement>('#fixed-row-tpl');
  const monthPrev      = $<HTMLButtonElement>('#month-prev');
  const monthNext      = $<HTMLButtonElement>('#month-next');
  const dateInput      = $<HTMLInputElement>('#date');
  const paidBySelect   = $<HTMLSelectElement>('#paidBy');
  const personSelect   = $<HTMLSelectElement>('#income-person');
  const fixedPaidBySel = $<HTMLSelectElement>('#fixed-paidBy');
  const fixedForm      = $<HTMLFormElement>('#fixed-form');
  const fixedList      = $<HTMLUListElement>('#fixed-list');
  const fixedEmpty     = $<HTMLParagraphElement>('#fixed-empty');
  const fixedTotalEl   = $<HTMLSpanElement>('#fixed-total');
  const incomeForm     = $<HTMLFormElement>('#income-form');
  const hideBtn        = $<HTMLButtonElement>('#hide-btn');
  const logoutBtn      = $<HTMLButtonElement>('#logout-btn');
  const copyCodeBtn    = $<HTMLButtonElement>('#copy-code-btn');
  const pageEl         = $<HTMLDivElement>('#page');
  const settingsHide   = $<HTMLButtonElement>('#settings-hide-btn');
  const settingsLogout = $<HTMLButtonElement>('#settings-logout-btn');
  const settingsCopy   = $<HTMLButtonElement>('#settings-copy-btn');
  const navItems = [...document.querySelectorAll<HTMLButtonElement>('.mobile-nav [data-view]')];
  const addTabs  = [...document.querySelectorAll<HTMLButtonElement>('.add-tab')];
  const desktopTabs = [...document.querySelectorAll<HTMLButtonElement>('.desktop-tab')];

  // ── Popup de edición ──
  const editModal      = $<HTMLDivElement>('#edit-modal');
  const editForm       = $<HTMLFormElement>('#edit-form');
  const editTitle      = $<HTMLHeadingElement>('#edit-modal-title');
  const editClose      = $<HTMLButtonElement>('#edit-close');
  const editDelete     = $<HTMLButtonElement>('#edit-delete');
  const editDesc       = $<HTMLInputElement>('#edit-description');
  const editAmount     = $<HTMLInputElement>('#edit-amount');
  const editDate       = $<HTMLInputElement>('#edit-date');
  const editCategory   = $<HTMLSelectElement>('#edit-category');
  const editPaidBy     = $<HTMLSelectElement>('#edit-paidBy');
  const editType       = $<HTMLSelectElement>('#edit-type');
  const editPerson     = $<HTMLSelectElement>('#edit-person');
  const editExpenseFld = $<HTMLDivElement>('#edit-expense-fields');
  const editIncomeFld  = $<HTMLDivElement>('#edit-income-fields');

  /** Movimiento que se está editando en el popup (o null si está cerrado). */
  let editing: { kind: 'expense' | 'income'; id: string } | null = null;

  const mobileMq = window.matchMedia('(max-width: 820px)');
  const isMobile = (): boolean => mobileMq.matches;

  /**
   * Convierte un <select> en un combobox con búsqueda: se escribe para filtrar
   * las categorías (p. ej. "co" → "Coca-Cola", "Comida"…) y se elige una de la
   * lista. El <select> original queda oculto pero sigue guardando el valor, así
   * que el envío del formulario no cambia. Tras asignar `select.value` por
   * código hay que llamar a `select._comboSync()` para refrescar el texto.
   */
  function enhanceSelectSearch(select: HTMLSelectElement): void {
    const wrap = document.createElement('div');
    wrap.className = 'combo';
    select.parentNode!.insertBefore(wrap, select);
    wrap.appendChild(select);
    select.classList.add('combo-native');

    const input = document.createElement('input');
    input.type = 'text';
    input.className = 'combo-input';
    input.autocomplete = 'off';
    input.setAttribute('role', 'combobox');
    input.setAttribute('aria-expanded', 'false');
    input.placeholder = 'Buscar categoría…';

    const menu = document.createElement('ul');
    menu.className = 'combo-menu';
    menu.hidden = true;

    wrap.appendChild(input);
    wrap.appendChild(menu);

    const opts = [...select.options].map((o) => ({ value: o.value, label: o.text }));
    let filtered = opts;
    let activeIdx = -1;

    const norm = (s: string): string =>
      s.toLowerCase().normalize('NFD').replace(/[̀-ͯ]/g, '');
    const labelFor = (value: string): string =>
      opts.find((o) => o.value === value)?.label ?? '';
    const syncFromSelect = (): void => { input.value = labelFor(select.value); };

    function renderMenu(): void {
      menu.textContent = '';
      if (!filtered.length) {
        const li = document.createElement('li');
        li.className = 'combo-empty';
        li.textContent = 'Sin resultados';
        menu.appendChild(li);
        return;
      }
      filtered.forEach((o, i) => {
        const li = document.createElement('li');
        li.className = 'combo-option' + (i === activeIdx ? ' is-active' : '');
        li.textContent = o.label;
        li.addEventListener('mousedown', (ev) => {
          ev.preventDefault();
          choose(o.value);
        });
        menu.appendChild(li);
      });
    }

    function applyFilter(q: string): void {
      const nq = norm(q.trim());
      filtered = nq ? opts.filter((o) => norm(o.label).includes(nq)) : opts;
      activeIdx = filtered.length ? 0 : -1;
      renderMenu();
    }

    function open(): void {
      applyFilter('');
      menu.hidden = false;
      input.setAttribute('aria-expanded', 'true');
    }

    function close(): void {
      menu.hidden = true;
      input.setAttribute('aria-expanded', 'false');
      activeIdx = -1;
      syncFromSelect();
    }

    function choose(value: string): void {
      select.value = value;
      select.dispatchEvent(new Event('change', { bubbles: true }));
      close();
    }

    input.addEventListener('focus', open);
    input.addEventListener('input', () => {
      menu.hidden = false;
      input.setAttribute('aria-expanded', 'true');
      applyFilter(input.value);
    });
    input.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowDown') {
        e.preventDefault();
        if (menu.hidden) { open(); return; }
        activeIdx = Math.min(activeIdx + 1, filtered.length - 1);
        renderMenu();
      } else if (e.key === 'ArrowUp') {
        e.preventDefault();
        activeIdx = Math.max(activeIdx - 1, 0);
        renderMenu();
      } else if (e.key === 'Enter') {
        if (!menu.hidden && filtered[activeIdx]) {
          e.preventDefault();
          choose(filtered[activeIdx]!.value);
        }
      } else if (e.key === 'Escape') {
        close();
      }
    });
    document.addEventListener('click', (e) => {
      if (!wrap.contains(e.target as Node)) close();
    });

    (select as unknown as { _comboSync: () => void })._comboSync = syncFromSelect;
    syncFromSelect();
  }

