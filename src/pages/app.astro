  const SVG_NS = 'http://www.w3.org/2000/svg';
  const donutWrap    = $<HTMLDivElement>('#donut-wrap');
  const chartCumHost = $<HTMLDivElement>('#chart-cum');
  const chartMonHost = $<HTMLDivElement>('#chart-months');
  const sparkHost    = $<HTMLDivElement>('#saldo-spark');

  function svgEl<K extends keyof SVGElementTagNameMap>(
    tag: K,
    attrs: Record<string, string | number> = {}
  ): SVGElementTagNameMap[K] {
    const el = document.createElementNS(SVG_NS, tag);
    for (const [k, v] of Object.entries(attrs)) el.setAttribute(k, String(v));
    return el;
  }

  /** Techo "lindo" para el eje Y (1 / 2 / 2,5 / 5 × 10^k). */
  function niceCeil(v: number): number {
    if (v <= 0) return 1;
    const base = Math.pow(10, Math.floor(Math.log10(v)));
    for (const m of [1, 2, 2.5, 5, 10]) {
      if (v <= m * base + 1e-9) return m * base;
    }
    return 10 * base;
  }

  /* ── Tooltip compartido por tarjeta de gráfico ── */
  interface TipRow {
    key?: string;
    label: string;
    value: string;
  }

  interface Tooltip {
    show(x: number, y: number, title: string, rows: TipRow[]): void;
    hide(): void;
  }

  function makeTooltip(host: HTMLElement): Tooltip {
    const tip = document.createElement('div');
    tip.className = 'chart-tip';
    tip.hidden = true;
    host.append(tip);
    return {
      show(x, y, title, rows) {
        tip.replaceChildren();
        const h = document.createElement('div');
        h.className = 'tip-title';
        h.textContent = title;
        tip.append(h);
        for (const r of rows) {
          const row = document.createElement('div');
          row.className = 'tip-row';
          if (r.key) {
            const k = document.createElement('i');
            k.className = 'tip-key';
            k.style.background = r.key;
            row.append(k);
          }
          const v = document.createElement('strong');
          v.className = 'tip-value';
          v.textContent = r.value;
          const l = document.createElement('span');
          l.className = 'tip-label';
          l.textContent = r.label;
          row.append(v, l);
          tip.append(row);
        }
        tip.hidden = false;
        const tw = tip.offsetWidth;
        const th = tip.offsetHeight;
        let left = x - tw / 2;
        left = Math.max(4, Math.min(left, host.clientWidth - tw - 4));
        let top = y - th - 10;
        if (top < 2) top = y + 16;
        tip.style.left = `${left}px`;
        tip.style.top = `${top}px`;
      },
      hide() {
        tip.hidden = true;
      },
    };
  }

  const donutTip = makeTooltip(donutWrap);
  const cumTip = makeTooltip(chartCumHost);
  const monTip = makeTooltip(chartMonHost);

  /* ── Dona por categoría (top 5 + resto, colores de cada categoría) ── */
  let donutCenter: HTMLDivElement | null = null;

  function renderDonut(combined: Expense[]): void {
    const slices = donutSlices(totalsByCategory(combined), 5);
    const totalAmt = slices.reduce((s, x) => s + x.amount, 0);

    donutWrap.querySelector('svg')?.remove();
    donutWrap.querySelector('.donut-shimmer')?.remove();
    if (!donutCenter) {
      donutCenter = document.createElement('div');
      donutCenter.className = 'donut-center';
      donutCenter.append(document.createElement('strong'), document.createElement('span'));
      donutWrap.append(donutCenter);
    }
    const centerValue = donutCenter.querySelector('strong')!;
    const centerLabel = donutCenter.querySelector('span')!;
    centerLabel.textContent = totalAmt > 0 ? 'gastado' : 'sin gastos';

    const size = 168;
    const r = 60;
    const C = 2 * Math.PI * r;
    const svg = svgEl('svg', { viewBox: `0 0 ${size} ${size}`, class: 'donut-svg', role: 'img' });
    svg.setAttribute('aria-label', `Gasto por categoría del mes: ${money(totalAmt)} en total`);

    // Anillo de fondo (siempre visible, también con la dona vacía).
    svg.append(
      svgEl('circle', {
        cx: size / 2,
        cy: size / 2,
        r,
        fill: 'none',
        stroke: 'rgba(148,163,197,0.13)',
        'stroke-width': 16,
      })
    );

    if (totalAmt <= 0) {
      centerValue.textContent = '—';
      donutWrap.append(svg);
      return;
    }
    animateNumber(centerValue, totalAmt, moneyCompact);

    // Los segmentos arrancan a las 12 en punto.
    const g = svgEl('g', { transform: `rotate(-90 ${size / 2} ${size / 2})` });
    const gap = slices.length > 1 ? 3 : 0;
    let acc = 0;

    slices.forEach((slice, i) => {
      const frac = slice.amount / totalAmt;
      const segLen = Math.max(0.5, frac * C - gap);
      const cat = slice.category ? getCategory(slice.category) : null;
      const color = cat ? cat.color : '#64748b';
      const label = cat ? `${cat.emoji} ${cat.label}` : '📦 Resto';
      const pctTxt = `${Math.round(frac * 100)}%`;

      const seg = svgEl('circle', {
        cx: size / 2,
        cy: size / 2,
        r,
        fill: 'none',
        stroke: color,
        'stroke-width': 16,
        'stroke-dasharray': `0 ${C}`,
        'stroke-dashoffset': -(acc + gap / 2),
        class: 'donut-seg',
        tabindex: 0,
        role: 'img',
      });
      seg.setAttribute('aria-label', `${label}: ${money(slice.amount)} (${pctTxt} del mes)`);
      seg.style.transitionDelay = `${140 + i * 90}ms`;
      seg.addEventListener('transitionend', () => (seg.style.transitionDelay = '0ms'), { once: true });

      const segMid = acc + (frac * C) / 2;
      const showTip = (): void => {
        seg.classList.add('is-hot');
        const ang = (segMid / C) * 2 * Math.PI - Math.PI / 2;
        const scale = (donutWrap.clientWidth || size) / size;
        donutTip.show(
          (size / 2 + Math.cos(ang) * r) * scale,
          (size / 2 + Math.sin(ang) * r) * scale,
          label,
          [{ key: color, label: pctTxt, value: money(slice.amount) }]
        );
      };
      const hideTip = (): void => {
        seg.classList.remove('is-hot');
        donutTip.hide();
      };
      seg.addEventListener('pointerenter', showTip);
      seg.addEventListener('pointerleave', hideTip);
      seg.addEventListener('focus', showTip);
      seg.addEventListener('blur', hideTip);

      g.append(seg);
      acc += frac * C;

      // Doble rAF: primero se monta con arco 0, después barre hasta su tamaño.
      requestAnimationFrame(() =>
        requestAnimationFrame(() => seg.setAttribute('stroke-dasharray', `${segLen} ${C - segLen}`))
      );
    });

    svg.append(g);
    donutWrap.append(svg);
  }

  /* ── Sparkline de saldo (últimos 6 meses) dentro de la tarjeta de saldo ── */
  function renderSparkline(series: MonthlyPoint[]): void {
    sparkHost.replaceChildren();
    if (series.every((p) => p.saldo === 0)) return;

    const w = 150;
    const h = 34;
    const pad = 4;
    const vals = series.map((p) => p.saldo);
    const min = Math.min(...vals, 0);
    const max = Math.max(...vals, 0);
    const span = max - min || 1;
    const x = (i: number): number => pad + (i * (w - pad * 2)) / Math.max(1, series.length - 1);
    const y = (v: number): number => pad + (h - pad * 2) * (1 - (v - min) / span);

    const svg = svgEl('svg', { viewBox: `0 0 ${w} ${h}`, class: 'spark-svg', 'aria-hidden': 'true' });
    if (min < 0 && max > 0) {
      svg.append(svgEl('line', { x1: pad, x2: w - pad, y1: y(0), y2: y(0), class: 'spark-zero' }));
    }
    const d = vals.map((v, i) => `${i === 0 ? 'M' : 'L'}${x(i).toFixed(1)} ${y(v).toFixed(1)}`).join(' ');
    const path = svgEl('path', { d, class: 'spark-line' });
    svg.append(path);
    svg.append(svgEl('circle', { cx: x(vals.length - 1), cy: y(vals[vals.length - 1]!), r: 3, class: 'spark-dot' }));
    sparkHost.append(svg);

    const len = path.getTotalLength();
    path.style.strokeDasharray = String(len);
    path.style.strokeDashoffset = String(len);
    requestAnimationFrame(() =>
      requestAnimationFrame(() => {
        path.style.strokeDashoffset = '0';
      })
    );
  }

  /* ── Gráfico de área: gasto acumulado del mes vs mes anterior ── */
  let lastCumW = 0;

  function renderCumulativeChart(skipAnim = false): void {
    const host = chartCumHost;
    host.querySelector('svg')?.remove();
    host.querySelector('.chart-shimmer')?.remove();
    host.querySelector('.chart-empty-note')?.remove();

    const W = Math.max(280, host.clientWidth || 0);
    lastCumW = W;
    const H = 232;
    const padL = 56;
    const padR = 18;
    const padT = 16;
    const padB = 28;
    const innerW = W - padL - padR;
    const innerH = H - padT - padB;

    const curKey = monthKeyOf(todayISO());
    const isCurrent = selectedMonth === curKey;
    const prevKey = shiftMonth(selectedMonth, -1);

    const cur = cumulativeByDay(expenses, fixed, selectedMonth);
    const prevAll = cumulativeByDay(expenses, fixed, prevKey);
    const prevHasData = expenses.some((e) => monthKeyOf(e.date) === prevKey);
    const todayDay = Number(todayISO().slice(8, 10));
    const curShown = isCurrent ? cur.slice(0, todayDay) : cur;
    const days = Math.max(cur.length, prevHasData ? prevAll.length : 0);

    // Leyenda del mes anterior solo si hay línea de contexto.
    document.querySelector<HTMLElement>('#lg-prev')?.toggleAttribute('hidden', !prevHasData);

    const curFinal = curShown[curShown.length - 1] ?? 0;
    if (curFinal <= 0 && !prevHasData) {
      const note = document.createElement('p');
      note.className = 'chart-empty-note';
      note.textContent = 'Sin gastos este mes todavía. El gráfico se dibuja solo. ✨';
      host.append(note);
      fillCumTable(curShown, prevAll, prevHasData);
      return;
    }

    const yMax = niceCeil(Math.max(curFinal, prevHasData ? prevAll[prevAll.length - 1] ?? 0 : 0, 1));
    const x = (i: number): number => padL + (i * innerW) / Math.max(1, days - 1);
    const y = (v: number): number => padT + innerH * (1 - v / yMax);

    const svg = svgEl('svg', { viewBox: `0 0 ${W} ${H}`, width: W, height: H, class: 'chart-svg' });

    // Grilla y etiquetas del eje Y
    const steps = 4;
    for (let s = 0; s <= steps; s++) {
      const gy = padT + (innerH * s) / steps;
      svg.append(svgEl('line', { x1: padL, x2: W - padR, y1: gy, y2: gy, class: 'grid-line' }));
      const t = svgEl('text', { x: padL - 8, y: gy + 4, class: 'axis-label', 'text-anchor': 'end' });
      t.textContent = moneyCompact(yMax * (1 - s / steps));
      svg.append(t);
    }

    // Etiquetas del eje X (día del mes)
    const dayStep = days > 21 ? 5 : days > 10 ? 3 : 2;
    for (let d = 1; d <= days; d += dayStep) {
      const t = svgEl('text', { x: x(d - 1), y: H - 8, class: 'axis-label', 'text-anchor': 'middle' });
      t.textContent = String(d);
      svg.append(t);
    }

    const defs = svgEl('defs');
    const grad = svgEl('linearGradient', { id: 'cum-fill', x1: 0, y1: 0, x2: 0, y2: 1 });
    grad.append(
      svgEl('stop', { offset: '0%', 'stop-color': 'rgba(99,102,241,0.30)' }),
      svgEl('stop', { offset: '100%', 'stop-color': 'rgba(99,102,241,0)' })
    );
    defs.append(grad);
    svg.append(defs);

    // Mes anterior: línea de contexto en gris
    if (prevHasData) {
      const dPrev = prevAll
        .map((v, i) => `${i === 0 ? 'M' : 'L'}${x(i).toFixed(1)} ${y(v).toFixed(1)}`)
        .join(' ');
      svg.append(svgEl('path', { d: dPrev, class: 'cum-line-prev' }));
    }

    // Mes seleccionado: área + línea + marcador final con etiqueta directa
    if (curShown.length > 0) {
      const dCur = curShown
        .map((v, i) => `${i === 0 ? 'M' : 'L'}${x(i).toFixed(1)} ${y(v).toFixed(1)}`)
        .join(' ');
      const lastI = curShown.length - 1;
      const area = svgEl('path', {
        d: `${dCur} L${x(lastI).toFixed(1)} ${y(0)} L${x(0)} ${y(0)} Z`,
        fill: 'url(#cum-fill)',
        class: 'cum-area',
      });
      const line = svgEl('path', { d: dCur, class: 'cum-line' });
      const dot = svgEl('circle', { cx: x(lastI), cy: y(curFinal), r: 4.5, class: 'cum-dot' });
      const lblAnchor = lastI / Math.max(1, days - 1) > 0.72 ? 'end' : 'middle';
      const lbl = svgEl('text', {
        x: x(lastI) - (lblAnchor === 'end' ? 8 : 0),
        y: Math.max(padT + 12, y(curFinal) - 12),
        class: 'chart-endlabel',
        'text-anchor': lblAnchor,
      });
      lbl.textContent = moneyCompact(curFinal);
      svg.append(area, line, dot, lbl);

      if (skipAnim || REDUCED_MOTION) {
        area.classList.add('is-on');
        dot.classList.add('is-on');
        lbl.classList.add('is-on');
      } else {
        const len = line.getTotalLength();
        line.style.strokeDasharray = String(len);
        line.style.strokeDashoffset = String(len);
        requestAnimationFrame(() =>
          requestAnimationFrame(() => {
            line.style.transition = 'stroke-dashoffset 1s cubic-bezier(0.4, 0, 0.2, 1)';
            line.style.strokeDashoffset = '0';
            area.classList.add('is-on');
            dot.classList.add('is-on');
            lbl.classList.add('is-on');
          })
        );
      }
    }

    // Crosshair + capa de hover (tooltip con las dos series en el día X)
    const cross = svgEl('line', { y1: padT, y2: padT + innerH, x1: 0, x2: 0, class: 'crosshair' });
    cross.setAttribute('visibility', 'hidden');
    const hover = svgEl('rect', {
      x: padL,
      y: padT,
      width: innerW,
      height: innerH,
      fill: 'transparent',
      class: 'hover-layer',
      tabindex: 0,
      role: 'img',
    });
    hover.setAttribute(
      'aria-label',
      'Gasto acumulado por día. Con el teclado, usá las flechas para recorrer los días.'
    );

    let hoverIdx = -1;
    const showAt = (i: number): void => {
      hoverIdx = Math.max(0, Math.min(days - 1, i));
      const px = x(hoverIdx);
      cross.setAttribute('x1', String(px));
      cross.setAttribute('x2', String(px));
      cross.setAttribute('visibility', 'visible');
      const rows: TipRow[] = [];
      if (hoverIdx < curShown.length) {
        rows.push({ key: 'var(--chart-gasto)', label: 'este mes', value: money(curShown[hoverIdx]!) });
      }
      if (prevHasData && hoverIdx < prevAll.length) {
        rows.push({ key: 'var(--chart-context)', label: formatMonthShort(prevKey), value: money(prevAll[hoverIdx]!) });
      }
      cumTip.show(px, padT + 6, `Día ${hoverIdx + 1}`, rows);
    };
    const hideTip = (): void => {
      cross.setAttribute('visibility', 'hidden');
      cumTip.hide();
    };

    hover.addEventListener('pointermove', (ev) => {
      const rect = svg.getBoundingClientRect();
      const px = ev.clientX - rect.left;
      showAt(Math.round(((px - padL) / innerW) * (days - 1)));
    });
    hover.addEventListener('pointerleave', hideTip);
    hover.addEventListener('focus', () => showAt(hoverIdx < 0 ? curShown.length - 1 : hoverIdx));
    hover.addEventListener('blur', hideTip);
    hover.addEventListener('keydown', (ev) => {
      if (ev.key === 'ArrowLeft') {
        ev.preventDefault();
        showAt(hoverIdx - 1);
      } else if (ev.key === 'ArrowRight') {
        ev.preventDefault();
        showAt(hoverIdx + 1);
      }
    });

    svg.append(cross, hover);
    host.append(svg);
    fillCumTable(curShown, prevAll, prevHasData);
  }

  /* ── Gráfico de columnas: gastos e ingresos de los últimos 6 meses ── */
  let lastMonW = 0;
  let lastSeries: MonthlyPoint[] = [];

  /** Columna con la punta redondeada (4px) y la base recta, como manda la casa. */
  function roundedColumnPath(cx: number, top: number, w: number, h: number): string {
    const r = Math.min(4, w / 2, h);
    const x0 = cx;
    const x1 = cx + w;
    const yB = top + h;
    return [
      `M${x0.toFixed(1)} ${yB.toFixed(1)}`,
      `L${x0.toFixed(1)} ${(top + r).toFixed(1)}`,
      `Q${x0.toFixed(1)} ${top.toFixed(1)} ${(x0 + r).toFixed(1)} ${top.toFixed(1)}`,
      `L${(x1 - r).toFixed(1)} ${top.toFixed(1)}`,
      `Q${x1.toFixed(1)} ${top.toFixed(1)} ${x1.toFixed(1)} ${(top + r).toFixed(1)}`,
      `L${x1.toFixed(1)} ${yB.toFixed(1)}`,
      'Z',
    ].join(' ');
  }

  function renderMonthsChart(series: MonthlyPoint[], skipAnim = false): void {
    const host = chartMonHost;
    lastSeries = series;
    host.querySelector('svg')?.remove();
    host.querySelector('.chart-shimmer')?.remove();

    const W = Math.max(280, host.clientWidth || 0);
    lastMonW = W;
    const H = 232;
    const padL = 56;
    const padR = 10;
    const padT = 16;
    const padB = 30;
    const innerW = W - padL - padR;
    const innerH = H - padT - padB;

    const yMax = niceCeil(Math.max(...series.map((p) => Math.max(p.gastos, p.ingresos)), 1));
    const band = innerW / series.length;
    const colW = Math.max(10, Math.min(22, Math.floor(band * 0.24)));

    const svg = svgEl('svg', { viewBox: `0 0 ${W} ${H}`, width: W, height: H, class: 'chart-svg' });

    const steps = 4;
    for (let s = 0; s <= steps; s++) {
      const gy = padT + (innerH * s) / steps;
      svg.append(svgEl('line', { x1: padL, x2: W - padR, y1: gy, y2: gy, class: 'grid-line' }));
      const t = svgEl('text', { x: padL - 8, y: gy + 4, class: 'axis-label', 'text-anchor': 'end' });
      t.textContent = moneyCompact(yMax * (1 - s / steps));
      svg.append(t);
    }

    series.forEach((p, i) => {
      const cx = padL + band * i + band / 2;
      const group = svgEl('g', { class: 'month-group' });

      const mkCol = (val: number, offset: number, cls: string, delay: number): void => {
        if (val <= 0) return;
        const h = Math.max(2, (val / yMax) * innerH);
        const col = svgEl('path', {
          d: roundedColumnPath(cx + offset, padT + innerH - h, colW, h),
          class: `col ${cls}`,
        });
        if (skipAnim || REDUCED_MOTION) {
          col.classList.add('is-grown');
          col.style.transition = 'none';
        } else {
          col.style.transitionDelay = `${delay}ms`;
          col.addEventListener('transitionend', () => (col.style.transitionDelay = '0ms'), { once: true });
          requestAnimationFrame(() => requestAnimationFrame(() => col.classList.add('is-grown')));
        }
        group.append(col);
      };
      // 2px de aire entre las dos columnas del grupo.
      mkCol(p.gastos, -colW - 1, 'col-gasto', i * 55);
      mkCol(p.ingresos, 1, 'col-ingreso', i * 55 + 90);

      const xl = svgEl('text', {
        x: cx,
        y: H - 8,
        class: `axis-label${p.month === selectedMonth ? ' axis-label-current' : ''}`,
        'text-anchor': 'middle',
      });
      xl.textContent = formatMonthShort(p.month);

      const hb = svgEl('rect', {
        x: padL + band * i,
        y: padT,
        width: band,
        height: innerH,
        fill: 'transparent',
        class: 'band-hover',
        tabindex: 0,
        role: 'img',
      });
      hb.setAttribute(
        'aria-label',
        `${formatMonth(p.month)}: gastos ${money(p.gastos)}, ingresos ${money(p.ingresos)}, saldo ${money(p.saldo)}`
      );
      const show = (): void => {
        group.classList.add('is-hot');
        monTip.show(cx, padT + 4, formatMonth(p.month), [
          { key: 'var(--chart-gasto)', label: 'gastos', value: money(p.gastos) },
          { key: 'var(--chart-ingreso)', label: 'ingresos', value: money(p.ingresos) },
          { label: 'saldo', value: money(p.saldo) },
        ]);
      };
      const hide = (): void => {
        group.classList.remove('is-hot');
        monTip.hide();
      };
      hb.addEventListener('pointerenter', show);
      hb.addEventListener('pointerleave', hide);
      hb.addEventListener('focus', show);
      hb.addEventListener('blur', hide);

      svg.append(group, xl, hb);
    });

    host.append(svg);
    fillMonthsTable(series);
  }

  /* ── Tablas "Ver datos": el gemelo accesible de cada gráfico ── */
  function tableRow(cells: string[], header = false): HTMLTableRowElement {
    const tr = document.createElement('tr');
    for (const c of cells) {
      const cell = document.createElement(header ? 'th' : 'td');
      cell.textContent = c;
      tr.append(cell);
    }
    return tr;
  }

  function fillCumTable(cur: number[], prev: number[], prevHasData: boolean): void {
    const table = $<HTMLTableElement>('#table-cum');
    table.replaceChildren();
    table.append(tableRow(prevHasData ? ['Día', 'Este mes', 'Mes anterior'] : ['Día', 'Este mes'], true));
    const days = Math.max(cur.length, prevHasData ? prev.length : 0);
    for (let d = 0; d < days; d++) {
      const cells = [String(d + 1), d < cur.length ? money(cur[d]!) : '—'];
      if (prevHasData) cells.push(d < prev.length ? money(prev[d]!) : '—');
      table.append(tableRow(cells));
    }
  }

  function fillMonthsTable(series: MonthlyPoint[]): void {
    const table = $<HTMLTableElement>('#table-months');
    table.replaceChildren();
    table.append(tableRow(['Mes', 'Gastos', 'Ingresos', 'Saldo'], true));
    for (const p of series) {
      table.append(tableRow([formatMonth(p.month), money(p.gastos), money(p.ingresos), money(p.saldo)]));
    }
  }

  /* ── KPIs de la sección de estadísticas ── */
  function renderStats(monthly: Expense[], monthIncome: Income[]): void {
    const combined = [...monthly, ...fixedAsExpenses(fixed, selectedMonth)];
    const gastoTotal = total(combined);
    const ingresoTot = incomeTotal(monthIncome);
    const saldo = ingresoTot - gastoTotal;
    const series = monthlySeries(expenses, income, fixed, selectedMonth, 6);

    const movs = monthly.length + monthIncome.length;
    $<HTMLSpanElement>('#stats-sub').textContent =
      `${formatMonth(selectedMonth)} · ${movs} ${movs === 1 ? 'movimiento' : 'movimientos'}`;

    const curKey = monthKeyOf(todayISO());
    const isCurrent = selectedMonth === curKey;
    const daysTotal = daysInMonth(selectedMonth);
    const elapsed = isCurrent ? Number(todayISO().slice(8, 10)) : daysTotal;

    // Promedio diario
    const avg = gastoTotal / Math.max(1, elapsed);
    animateNumber($<HTMLElement>('#kpi-avg'), avg, money);
    $<HTMLElement>('#kpi-avg-hint').textContent = isCurrent
      ? `en ${elapsed} ${elapsed === 1 ? 'día' : 'días'} de mes`
      : `mes completo · ${daysTotal} días`;

    // Proyección (mes en curso) o total (mes cerrado)
    const projLabel = $<HTMLElement>('#kpi-proj-label');
    if (isCurrent) {
      projLabel.textContent = 'Proyección del mes';
      animateNumber($<HTMLElement>('#kpi-proj'), avg * daysTotal, money);
      const rest = daysTotal - elapsed;
      $<HTMLElement>('#kpi-proj-hint').textContent =
        rest > 0 ? `a este ritmo · faltan ${rest} ${rest === 1 ? 'día' : 'días'}` : 'último día del mes';
    } else {
      projLabel.textContent = 'Total gastado';
      animateNumber($<HTMLElement>('#kpi-proj'), gastoTotal, money);
      $<HTMLElement>('#kpi-proj-hint').textContent = 'mes cerrado';
    }

    // Variación de gastos contra el mes anterior
    const prev = series[series.length - 2];
    const prevGasto = prev?.gastos ?? 0;
    const deltaEl = $<HTMLElement>('#kpi-delta');
    deltaEl.classList.remove('delta-up', 'delta-down');
    if (prevGasto <= 0) {
      deltaEl.textContent = '—';
      $<HTMLElement>('#kpi-delta-hint').textContent = 'sin gastos el mes anterior';
    } else {
      const pctDelta = ((gastoTotal - prevGasto) / prevGasto) * 100;
      const fmtPct = (v: number): string =>
        moneyHidden
          ? '···'
          : `${v > 0.05 ? '▲ +' : v < -0.05 ? '▼ ' : '• '}${v.toFixed(1).replace('.', ',')}%`;
      animateNumber(deltaEl, pctDelta, fmtPct);
      deltaEl.classList.toggle('delta-up', pctDelta > 0.05);
      deltaEl.classList.toggle('delta-down', pctDelta < -0.05);
      $<HTMLElement>('#kpi-delta-hint').textContent =
        `${money(prevGasto)} en ${formatMonthShort(prev?.month ?? shiftMonth(selectedMonth, -1))}`;
    }

    // Tasa de ahorro (con medidor)
    const saveEl = $<HTMLElement>('#kpi-save');
    const meter = $<HTMLDivElement>('#kpi-save-meter');
    const fill = $<HTMLElement>('#kpi-save-fill');
    const saveHint = $<HTMLElement>('#kpi-save-hint');
    meter.hidden = ingresoTot <= 0;
    if (ingresoTot <= 0) {
      saveEl.textContent = '—';
      saveHint.textContent = 'sin ingresos este mes';
    } else {
      const rate = (saldo / ingresoTot) * 100;
      animateNumber(saveEl, rate, (v) => (moneyHidden ? '···' : `${v.toFixed(0)}%`));
      fill.className = `meter-fill ${rate >= 20 ? 'meter-ok' : rate > 0 ? 'meter-warn' : 'meter-bad'}`;
      requestAnimationFrame(() => {
        fill.style.width = `${Math.max(0, Math.min(100, rate))}%`;
      });
      saveHint.textContent =
        rate > 0
          ? `${rate >= 20 ? '💪' : '🙂'} guardás ${money(saldo)} de ${money(ingresoTot)}`
          : `🚨 gastás ${money(-saldo)} más de lo que entra`;
    }

    renderSparkline(series);
    renderCumulativeChart();
    renderMonthsChart(series);
    lastChartsRenderT = performance.now();
  }

  // Redibujar los gráficos si cambia el ancho disponible. Si pasa apenas
  // cargada la página (p. ej. por un reflow inicial), se conserva la
  // animación de dibujo; después, se redibuja sin re-animar.
  let roRaf = 0;
  let lastChartsRenderT = 0;
  const chartsRO = new ResizeObserver(() => {
    cancelAnimationFrame(roRaf);
    roRaf = requestAnimationFrame(() => {
      const skipAnim = performance.now() - lastChartsRenderT > 800;
      if (chartCumHost.clientWidth > 0 && Math.abs(chartCumHost.clientWidth - lastCumW) > 1) {
        renderCumulativeChart(skipAnim);
      }
      if (
        chartMonHost.clientWidth > 0 &&
        lastSeries.length > 0 &&
        Math.abs(chartMonHost.clientWidth - lastMonW) > 1
      ) {
        renderMonthsChart(lastSeries, skipAnim);
      }
    });
  });
  chartsRO.observe(chartCumHost);
  chartsRO.observe(chartMonHost);

  /* ── Popup de edición / eliminación de movimientos ── */
  function makeClickableRow(node: HTMLLIElement, onOpen: () => void): void {
    node.classList.add('is-clickable');
    node.setAttribute('role', 'button');
    node.tabIndex = 0;
    node.title = 'Tocar para editar o eliminar';
    node.addEventListener('click', onOpen);
    node.addEventListener('keydown', (ev) => {
      if (ev.key === 'Enter' || ev.key === ' ') {
        ev.preventDefault();
        onOpen();
      }
    });
  }

  function openEditModal(): void {
    editModal.hidden = false;
    document.body.classList.add('modal-open');
    editDesc.focus();
  }

  function closeEditModal(): void {
    editModal.hidden = true;
    document.body.classList.remove('modal-open');
    editing = null;
  }

  function openEditExpense(e: Expense): void {
    editing = { kind: 'expense', id: e.id };
    editTitle.textContent = 'Editar gasto';
    editExpenseFld.hidden = false;
    editIncomeFld.hidden = true;
    editDesc.value = e.description;
    editAmount.value = String(e.amount);
    editDate.value = e.date;
    editCategory.value = e.category;
    comboSync(editCategory);
    editPaidBy.value = e.paidBy;
    openEditModal();
  }

  function openEditIncome(inc: Income): void {
    editing = { kind: 'income', id: inc.id };
    editTitle.textContent = 'Editar ingreso';
    editExpenseFld.hidden = true;
    editIncomeFld.hidden = false;
    editDesc.value = inc.description;
    editAmount.value = String(inc.amount);
    editDate.value = inc.date;
    editType.value = inc.type;
    editPerson.value = inc.person;
    openEditModal();
  }

  editClose.addEventListener('click', closeEditModal);
  editModal.addEventListener('click', (ev) => {
    if (ev.target === editModal) closeEditModal();
  });
  document.addEventListener('keydown', (ev) => {
    if (ev.key === 'Escape' && !editModal.hidden) closeEditModal();
  });

  editForm.addEventListener('submit', async (ev) => {
    ev.preventDefault();
    if (!editing) return;
    const fd = new FormData(editForm);
    const amount = Number.parseFloat(String(fd.get('amount')).replace(',', '.'));
    if (!Number.isFinite(amount) || amount <= 0) {
      editAmount.focus();
      return;
    }
    const description = String(fd.get('description')).trim();
    const date = String(fd.get('date')) || todayISO();
    const rounded = Math.round(amount * 100) / 100;
    try {
      if (editing.kind === 'expense') {
        const updated = await apiUpdateExpense(editing.id, {
          description,
          amount: rounded,
          category: String(fd.get('category')) as CategoryId,
          paidBy: String(fd.get('paidBy')).trim(),
          date,
        });
        expenses = expenses.map((x) => (x.id === updated.id ? updated : x));
      } else {
        const updated = await apiUpdateIncome(editing.id, {
          description,
          amount: rounded,
          type: String(fd.get('type')) as 'sueldo' | 'extra',
          person: String(fd.get('person')).trim(),
          date,
        });
        income = income.map((x) => (x.id === updated.id ? updated : x));
      }
    } catch (err) {
      alert(err instanceof Error ? err.message : 'No se pudo guardar el cambio.');
      return;
    }
    selectedMonth = monthKeyOf(date);
    closeEditModal();
    render();
  });

  editDelete.addEventListener('click', async () => {
    if (!editing) return;
    const { kind, id } = editing;
    const label = kind === 'expense' ? 'este gasto' : 'este ingreso';
    if (!confirm(`¿Eliminar ${label}? No se puede deshacer.`)) return;
    try {
      if (kind === 'expense') {
        await apiDeleteExpense(id);
        expenses = expenses.filter((x) => x.id !== id);
      } else {
        await apiDeleteIncome(id);
        income = income.filter((x) => x.id !== id);
      }
    } catch (err) {
      alert(err instanceof Error ? err.message : 'No se pudo eliminar el movimiento.');
      return;
    }
    closeEditModal();
    render();
  });

  function bindCopy(btn: HTMLButtonElement, doneText: string): void {
    const original = btn.textContent;
    btn.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(house.inviteCode);
        btn.textContent = doneText;
        setTimeout(() => (btn.textContent = original), 1500);
      } catch {
        // Sin clipboard: el código ya está visible al lado del botón.
      }
    });
  }
  bindCopy(copyCodeBtn, '✅');
  bindCopy(settingsCopy, '✅ Copiado');

  for (const btn of [logoutBtn, settingsLogout]) {
    btn.addEventListener('click', async () => {
      await apiLogout();
      window.location.assign('/');
    });
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const fd = new FormData(form);
    const amount = Number.parseFloat(String(fd.get('amount')).replace(',', '.'));
    if (!Number.isFinite(amount) || amount <= 0) {
      $<HTMLInputElement>('#amount').focus();
      return;
    }
    const date = String(fd.get('date')) || todayISO();
    const category = String(fd.get('category')) as CategoryId;
    const description = String(fd.get('description')).trim() || getCategory(category).label;
    try {
      const created = await apiAddExpense({
        description,
        amount: Math.round(amount * 100) / 100,
        category,
        paidBy: String(fd.get('paidBy')).trim(),
        date,
      });
      expenses = [...expenses, created];
    } catch (err) {
      alert(err instanceof Error ? err.message : 'No se pudo añadir el gasto.');
      return;
    }
    selectedMonth = monthKeyOf(date);
    form.reset();
    comboSync($<HTMLSelectElement>('#category'));
    dateInput.value = todayISO();
    paidBySelect.value = currentUser.displayName;
    if (isMobile()) {
      setView('movs');
    } else {
      $<HTMLInputElement>('#description').focus();
    }
    render();
  });

  incomeForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    const fd = new FormData(incomeForm);
    const amount = Number.parseFloat(String(fd.get('amount')).replace(',', '.'));
    if (!Number.isFinite(amount) || amount <= 0) {
      $<HTMLInputElement>('#income-amount').focus();
      return;
    }
    const date = String(fd.get('date')) || todayISO();
    try {
      const created = await apiAddIncome({
        description: String(fd.get('description')).trim(),
        amount: Math.round(amount * 100) / 100,
        type: String(fd.get('type')) as 'sueldo' | 'extra',
        person: String(fd.get('person')).trim(),
        date,
      });
      income = [...income, created];
    } catch (err) {
      alert(err instanceof Error ? err.message : 'No se pudo añadir el ingreso.');
      return;
    }
    selectedMonth = monthKeyOf(date);
    incomeForm.reset();
    $<HTMLInputElement>('#income-date').value = todayISO();
    personSelect.value = currentUser.displayName;
    if (isMobile()) {
      setView('movs');
    } else {
      $<HTMLInputElement>('#income-description').focus();
    }
    render();
  });

  fixedForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    const fd = new FormData(fixedForm);
    const amount = Number.parseFloat(String(fd.get('amount')).replace(',', '.'));
    if (!Number.isFinite(amount) || amount <= 0) {
      $<HTMLInputElement>('#fixed-amount').focus();
      return;
    }
    try {
      const created = await apiAddFixedCost({
        description: String(fd.get('description')).trim(),
        amount: Math.round(amount * 100) / 100,
        category: String(fd.get('category')) as CategoryId,
        paidBy: String(fd.get('paidBy')).trim(),
      });
      fixed = [...fixed, created];
    } catch (err) {
      alert(err instanceof Error ? err.message : 'No se pudo añadir el costo fijo.');
      return;
    }
    fixedForm.reset();
    comboSync($<HTMLSelectElement>('#fixed-category'));
    fixedPaidBySel.value = currentUser.displayName;
    if (!isMobile()) $<HTMLInputElement>('#fixed-description').focus();
    render();
  });

  for (const btn of [hideBtn, settingsHide]) {
    btn.addEventListener('click', () => {
      moneyHidden = !moneyHidden;
      localStorage.setItem(HIDE_KEY, moneyHidden ? '1' : '0');
      updateHideBtn();
      render();
    });
  }

  function updateHideBtn(): void {
    hideBtn.setAttribute('aria-pressed', String(moneyHidden));
    hideBtn.textContent = moneyHidden ? '🙈 Mostrar' : '👁️ Ocultar';
    hideBtn.title = moneyHidden ? 'Mostrar importes' : 'Ocultar importes';
    settingsHide.setAttribute('aria-pressed', String(moneyHidden));
    settingsHide.textContent = moneyHidden ? '🙈 Mostrar importes' : '👁️ Ocultar importes';
  }

  monthSelect.addEventListener('change', () => {
    selectedMonth = monthSelect.value;
    render();
  });

  monthPrev.addEventListener('click', () => {
    selectedMonth = shiftMonth(selectedMonth || monthKeyOf(todayISO()), -1);
    render();
  });
  monthNext.addEventListener('click', () => {
    selectedMonth = shiftMonth(selectedMonth || monthKeyOf(todayISO()), 1);
    render();
  });

  dateInput.value = todayISO();
  $<HTMLInputElement>('#income-date').value = todayISO();
  $<HTMLSelectElement>('#category').value = CATEGORIES[0]!.id;
  $<HTMLSelectElement>('#fixed-category').value = CATEGORIES[0]!.id;
  $<HTMLSelectElement>('#income-type').value = INCOME_TYPES[0]!.id;
  enhanceSelectSearch($<HTMLSelectElement>('#category'));
  enhanceSelectSearch($<HTMLSelectElement>('#fixed-category'));
  enhanceSelectSearch(editCategory);
  updateHideBtn();
  renderHouseHeader();
  populateMemberSelects();
  render();
</script>

